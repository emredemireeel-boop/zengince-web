<%- include('partials/header') %>

  <!-- Page Header -->
  <section class="page-header" style="background: linear-gradient(135deg, rgba(46, 204, 113, 0.1) 0%, rgba(20,20,20,1) 100%);">
    <div class="container">
      <span class="section-badge" style="background: rgba(46, 204, 113, 0.1); border-color: rgba(46, 204, 113, 0.3); color: #2ECC71;">💰 Bilge Rehberi</span>
      <h1 class="section-title" style="margin-top:12px;">En Etkili 10 <span style="color: #2ECC71;">Tasarruf ve Bütçe</span> Modeli</h1>
      <p class="section-desc" style="margin:8px auto 0;">Paranızı yönetmek için kendi karakterinize ve yaşam tarzınıza en uygun bütçeleme sistemini bulun.</p>
    </div>
  </section>

  <!-- Modeller Section -->
  <section class="section">
    <div class="container">
      <div class="grid-3 stagger-children">
        <% modeller.forEach(function(m) { %>
        <a href="/tasarruf-modelleri/<%= m.slug %>" style="text-decoration: none; display: flex; flex-direction: column;" class="film-card">
          <div class="film-card-body" style="padding: 24px; display: flex; flex-direction: column; flex: 1;">
            
            <div style="font-size: 3rem; margin-bottom: 16px;"><%= m.icon %></div>
            <h2 class="film-card-title" style="margin-bottom: 8px;"><%= m.baslik %></h2>
            <div class="film-card-meta" style="margin-bottom: 16px;">
              <span class="film-card-tur" style="background: var(--dark-400); color: var(--text-secondary);">Yazar/Kaynak: <%= m.yazar %></span>
            </div>
            
            <!-- Progress Bar Preview -->
            <div style="display: flex; width: 100%; height: 8px; border-radius: 4px; overflow: hidden; margin-bottom: 16px; background: var(--dark-400);">
              <% m.dagilim.forEach(function(d) { %>
                <div style="width: <%= d.yuzde %>%; background: <%= d.renk %>; height: 100%;"></div>
              <% }) %>
            </div>

            <p style="font-size:0.95rem;color:var(--text-secondary);line-height:1.6;margin-bottom:16px; flex: 1;"><%= m.kisaOzet %></p>
            
            <div style="margin-top: auto; padding-top: 16px; font-size: 0.9rem; color: #2ECC71; font-weight: 600; display: flex; align-items: center; gap: 4px; border-top: 1px solid var(--glass-border);">
              Detayları İncele <span style="font-size: 1.2rem;">→</span>
            </div>
          </div>
        </a>
        <% }); %>
      </div>
    </div>
  </section>

<%- include('partials/footer') %>
