<%- include('partials/header') %>

<section class="page-header" style="padding-bottom: 40px; text-align: left;">
  <div class="container">
    <a href="/filmler" style="display: inline-flex; align-items: center; gap: 6px; margin-bottom: 24px; color: var(--gold-200); font-weight: 600; text-decoration: none;">
      <span>←</span> Sinemaya Dön
    </a>
  </div>
</section>

<section class="section" style="padding-top: 0;">
  <div class="container">
    <div style="display: flex; gap: 60px; flex-wrap: wrap;">
      
      <!-- Sol Taraf: Film Afişi -->
      <div style="width: 320px; flex-shrink: 0;">
        <div class="card" style="padding: 16px; position: sticky; top: 100px;">
          <img src="<%= film.afisGorseli %>" alt="<%= film.baslik %>" style="width: 100%; border-radius: 8px; box-shadow: var(--shadow-lg); margin-bottom: 24px; display: block;">
          
          <div style="display: flex; flex-direction: column; gap: 12px;">
            <div style="display: flex; justify-content: space-between; align-items: center; padding-bottom: 12px; border-bottom: 1px solid var(--glass-border);">
              <span style="color: var(--text-muted); font-size: 0.9rem;">Yönetmen</span>
              <strong style="color: var(--white);"><%= film.yonetmen %></strong>
            </div>
            <div style="display: flex; justify-content: space-between; align-items: center; padding-bottom: 12px; border-bottom: 1px solid var(--glass-border);">
              <span style="color: var(--text-muted); font-size: 0.9rem;">Vizyon Yılı</span>
              <strong style="color: var(--white);"><%= film.yil %></strong>
            </div>
            <div style="display: flex; justify-content: space-between; align-items: center;">
              <span style="color: var(--text-muted); font-size: 0.9rem;">IMDb Puanı</span>
              <strong style="color: var(--gold-200); display: flex; align-items: center; gap: 4px;">⭐ <%= film.imdb %></strong>
            </div>
          </div>
        </div>
      </div>

      <!-- Sağ Taraf: İçerik -->
      <div style="flex: 1; min-width: 300px; max-width: 800px;">
        <h1 class="section-title" style="margin-bottom: 8px; font-size: clamp(2.2rem, 4vw, 3.5rem); line-height: 1.1;"><%= film.turkceBaslik || film.baslik %></h1>
        <h2 style="color: var(--text-muted); font-size: 1.5rem; margin-bottom: 24px; font-weight: 400;"><%= film.baslik !== film.turkceBaslik ? film.baslik : '' %></h2>
        
        <div style="margin-bottom: 40px; display: flex; gap: 12px;">
          <span style="display: inline-block; padding: 6px 16px; background: rgba(212,175,55,0.1); border: 1px solid rgba(212,175,55,0.3); border-radius: 100px; color: var(--gold-200); font-size: 0.85rem; font-weight: 600; text-transform: uppercase; letter-spacing: 1px;">
            <%= tur.baslik %>
          </span>
        </div>
        
        <!-- Kapsamlı Özet -->
        <div class="card" style="margin-bottom: 40px; padding: 40px;">
          <h3 style="color: var(--white); font-family: var(--font-display); font-size: 1.8rem; margin-bottom: 24px;">Film İncelemesi</h3>
          <div style="font-size: 1.1rem; line-height: 1.85; color: var(--text-secondary);">
            <p><%= film.detayliOzet %></p>
          </div>
        </div>

        <!-- Temel Öğrenimler Listesi -->
        <div class="card" style="background: linear-gradient(145deg, rgba(46, 204, 113, 0.08) 0%, rgba(20, 20, 20, 0.9) 100%); border-color: rgba(46, 204, 113, 0.2); padding: 40px; position: relative; overflow: hidden;">
          <div style="position: absolute; top: -10px; right: 10px; font-size: 8rem; opacity: 0.05;">🎓</div>
          <h3 style="color: var(--emerald); font-family: var(--font-display); font-size: 1.6rem; margin-bottom: 24px; position: relative; z-index: 1;">Finansal Zenginlik Dersleri</h3>
          <ul style="position: relative; z-index: 1; display: flex; flex-direction: column; gap: 16px;">
            <% film.temelOgrenimler.forEach(function(madde) { %>
              <li style="display: flex; gap: 12px; font-size: 1.05rem; color: var(--text-primary); line-height: 1.6;">
                <span style="color: var(--emerald); font-weight: 800;">✓</span>
                <span><%= madde %></span>
              </li>
            <% }); %>
          </ul>
        </div>

      </div>

    </div>
  </div>
</section>


<section class="section" style="padding-top: 0;">
  <div class="container">
    <%- include('partials/comments', { pageId: 'film_' + film.slug }) %>
  </div>
</section>

<%- include('partials/footer') %>
