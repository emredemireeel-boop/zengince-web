
<%- include('partials/header') %>

<main class="makale-detay-page">
  <div class="makale-hero" style="background-image: linear-gradient(to bottom, rgba(10,10,10,0.3) 0%, rgba(10,10,10,1) 100%), url('<%= aliskanlik.kapakGorseli %>'); background-position: center; background-size: cover;">
    <div class="makale-hero-content">
      <div class="makale-meta">
        <span class="makale-badge" style="background: var(--gold-600); color: var(--dark-bg); font-weight: bold; padding: 5px 12px; border-radius: 20px; font-size: 0.9rem;">
          <%= aliskanlik.ikon %> <%= kategoriAdi %>
        </span>
        <span class="makale-read-time" style="margin-left: 15px; color: #ccc;">
          <i class="far fa-clock"></i> Önerilen Zaman: <%= aliskanlik.saat %>
        </span>
      </div>
      <h1 class="makale-title" style="margin-top: 20px; font-family: 'Cormorant Garamond', serif; font-size: 3.5rem; color: var(--gold-400); text-shadow: 2px 2px 4px rgba(0,0,0,0.8);"><%= aliskanlik.baslik %></h1>
      <p style="margin-top: 15px; font-size: 1.2rem; color: #ddd; max-width: 800px; line-height: 1.6;"><%= aliskanlik.aciklama %></p>
    </div>
  </div>

  <div class="container" style="max-width: 800px; margin: 0 auto; padding: 60px 20px;">
    
    <div class="makale-content" style="font-family: 'Outfit', sans-serif; font-size: 1.15rem; line-height: 1.8; color: #e0e0e0;">
      <%- aliskanlik.detayliIcerik %>
    </div>
    
    <div class="makale-footer" style="margin-top: 60px; padding-top: 30px; border-top: 1px solid rgba(255,215,0,0.2); text-align: center;">
      <a href="/aliskanliklar" class="btn" style="background: transparent; border: 1px solid var(--gold-500); color: var(--gold-500); padding: 10px 20px; border-radius: 5px; text-decoration: none; transition: all 0.3s ease;">
        &larr; Diğer Alışkanlıklara Dön
      </a>
    </div>

  </div>
</main>

<style>
  .dropcap {
    float: left;
    font-family: 'Cormorant Garamond', serif;
    font-size: 5rem;
    line-height: 0.8;
    padding-top: 4px;
    padding-right: 15px;
    padding-left: 3px;
    color: var(--gold-500);
  }
  
  .makale-content h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.2rem;
    margin-bottom: 20px;
    border-bottom: 1px solid rgba(255,215,0,0.1);
    padding-bottom: 10px;
  }

  .makale-content h3 {
    font-family: 'Outfit', sans-serif;
    font-size: 1.5rem;
    color: #fff;
    margin-top: 30px;
    margin-bottom: 15px;
  }

  .article-alert {
    background: rgba(212, 175, 55, 0.05);
    border-left: 4px solid var(--gold-500);
    padding: 20px;
    margin: 30px 0;
    border-radius: 0 8px 8px 0;
    font-size: 1.1rem;
  }

  .habit-card:hover {
    transform: translateY(-5px) !important;
    box-shadow: 0 10px 30px rgba(212, 175, 55, 0.15) !important;
    border-color: var(--gold-600) !important;
  }
</style>


<section class="section" style="padding-top: 0;">
  <div class="container">
    <%- include('partials/comments', { pageId: 'aliskanlik_' + aliskanlik.slug }) %>
  </div>
</section>

<%- include('partials/footer') %>
