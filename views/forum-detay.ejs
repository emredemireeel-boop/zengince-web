<%- include('partials/header') %>

<!-- Forum CSS -->
<link rel="stylesheet" href="/forum.css">

<style>
  /* Premium Aesthetics for Forum Detail */
  .thread-hero {
    position: relative;
    padding: 80px 0 60px;
    background: linear-gradient(180deg, rgba(15,15,15,0.95) 0%, var(--background) 100%);
    border-bottom: 1px solid rgba(212, 175, 55, 0.1);
    margin-bottom: 40px;
    overflow: hidden;
  }

  .thread-hero::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(ellipse at 50% 0%, rgba(212, 175, 55, 0.15), transparent 50%);
    pointer-events: none;
    z-index: 0;
  }

  .thread-hero::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjAiIGhlaWdodD0iMjAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PGNpcmNsZSBjeD0iMiIgY3k9IjIiIHI9IjEiIGZpbGw9InJnYmEoMjEyLCAxNzUsIDU1LCAwLjA1KSIvPjwvc3ZnPg==') repeat;
    opacity: 0.5;
    z-index: 0;
  }

  .thread-header-content {
    position: relative;
    z-index: 1;
    max-width: 900px;
    margin: 0 auto;
    padding: 0 24px;
    animation: fadeInDown 0.8s var(--ease-out);
  }

  @keyframes fadeInDown {
    from { opacity: 0; transform: translateY(-20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .breadcrumb {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 18px;
    background: rgba(20,20,20,0.6);
    border: 1px solid rgba(212,175,55,0.15);
    border-radius: 100px;
    font-size: 13px;
    color: var(--text-muted);
    margin-bottom: 24px;
    backdrop-filter: blur(10px);
    box-shadow: 0 4px 15px rgba(0,0,0,0.2);
  }

  .breadcrumb a {
    color: var(--gold-300);
    text-decoration: none;
    font-weight: 600;
    transition: color 0.2s;
  }

  .breadcrumb a:hover {
    color: var(--gold-200);
  }

  .thread-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: #fff;
    margin-bottom: 24px;
    line-height: 1.15;
    letter-spacing: 0.01em;
    text-shadow: 0 4px 20px rgba(0,0,0,0.5);
  }

  .thread-meta-bar {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .meta-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 8px;
    font-size: 13px;
    font-weight: 600;
    color: var(--text-secondary);
    backdrop-filter: blur(10px);
    transition: all 0.3s;
  }

  .meta-pill:hover {
    background: rgba(255,255,255,0.08);
    border-color: rgba(255,255,255,0.15);
  }

  .meta-pill.highlight {
    background: rgba(212, 175, 55, 0.1);
    border-color: rgba(212, 175, 55, 0.25);
    color: var(--gold-200);
    box-shadow: 0 0 15px rgba(212,175,55,0.1);
  }

  .entry-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 24px 80px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .premium-entry-card {
    background: linear-gradient(145deg, rgba(30,30,30,0.6) 0%, rgba(15,15,15,0.8) 100%);
    border: 1px solid rgba(255,255,255,0.04);
    border-radius: 20px;
    padding: 32px;
    display: flex;
    gap: 28px;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: 0 8px 30px rgba(0,0,0,0.3);
    position: relative;
    overflow: hidden;
    backdrop-filter: blur(10px);
    
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInUp 0.6s var(--ease-out) forwards;
  }

  @keyframes fadeInUp {
    to { opacity: 1; transform: translateY(0); }
  }

  .premium-entry-card:nth-child(1) { animation-delay: 0.1s; }
  .premium-entry-card:nth-child(2) { animation-delay: 0.2s; }
  .premium-entry-card:nth-child(3) { animation-delay: 0.3s; }
  .premium-entry-card:nth-child(4) { animation-delay: 0.4s; }
  .premium-entry-card:nth-child(n+5) { animation-delay: 0.5s; }

  .premium-entry-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, rgba(212, 175, 55, 0.4), transparent);
    opacity: 0;
    transition: opacity 0.4s;
  }

  .premium-entry-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 40px rgba(0,0,0,0.5), 0 0 20px rgba(212,175,55,0.05);
    border-color: rgba(212, 175, 55, 0.2);
  }

  .premium-entry-card:hover::before {
    opacity: 1;
  }

  .entry-author-col {
    width: 130px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    border-right: 1px solid rgba(255,255,255,0.06);
    padding-right: 28px;
  }

  .avatar-wrap {
    width: 68px;
    height: 68px;
    border-radius: 50%;
    background: linear-gradient(135deg, #1f1f1f, #0a0a0a);
    border: 2px solid rgba(212, 175, 55, 0.4);
    color: var(--gold-200);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 26px;
    font-family: var(--font-display);
    font-weight: 700;
    margin-bottom: 16px;
    box-shadow: inset 0 2px 10px rgba(0,0,0,0.8), 0 4px 15px rgba(212, 175, 55, 0.2);
    position: relative;
    transition: transform 0.3s var(--ease-spring);
  }

  .avatar-wrap:hover {
    transform: scale(1.08);
  }

  .avatar-wrap::after {
    content: '';
    position: absolute;
    inset: -6px;
    border-radius: 50%;
    border: 1px dashed rgba(212, 175, 55, 0.3);
    animation: spin 15s linear infinite;
  }

  @keyframes spin { 100% { transform: rotate(360deg); } }

  .username {
    font-size: 15px;
    font-weight: 700;
    color: #fff;
    margin-bottom: 8px;
    text-align: center;
    word-break: break-all;
    transition: color 0.2s;
  }

  .username:hover {
    color: var(--gold-300);
  }

  .user-badge {
    font-size: 10px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    padding: 5px 12px;
    border-radius: 100px;
    background: rgba(255,255,255,0.05);
    color: var(--text-muted);
    text-align: center;
  }

  .user-badge.usta, .user-badge.efsane {
    background: linear-gradient(135deg, rgba(212,175,55,0.1) 0%, rgba(212,175,55,0.2) 100%);
    border: 1px solid rgba(212,175,55,0.3);
    color: var(--gold-200);
    box-shadow: 0 0 15px rgba(212, 175, 55, 0.15);
  }

  .entry-content-col {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .entry-text {
    font-size: 16px;
    color: #e8e8e3;
    line-height: 1.8;
    margin-bottom: 24px;
    white-space: pre-wrap;
    font-weight: 400;
  }

  .entry-actions {
    margin-top: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 18px;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .action-time {
    font-size: 13px;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .author-tag {
    font-size: 11px;
    font-weight: 700;
    padding: 4px 10px;
    background: linear-gradient(90deg, rgba(212, 175, 55, 0.15), transparent);
    color: var(--gold-200);
    border-radius: 4px;
    border-left: 2px solid var(--gold-300);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .btn-action {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 100px;
    color: var(--text-primary);
    font-weight: 600;
    font-size: 13px;
    cursor: pointer;
    transition: all 0.2s var(--ease-out);
  }

  .btn-action:hover {
    background: rgba(255,255,255,0.08);
    border-color: rgba(255,255,255,0.2);
  }

  .btn-upvote {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 18px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 100px;
    color: #fff;
    font-weight: 700;
    font-size: 14px;
    cursor: pointer;
    transition: all 0.3s var(--ease-spring);
  }

  .btn-upvote:hover {
    background: rgba(34, 197, 94, 0.1);
    border-color: rgba(34, 197, 94, 0.4);
    color: #22c55e;
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(34,197,94,0.15);
  }

  .btn-upvote.active {
    background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
    color: #fff;
    border-color: transparent;
    box-shadow: 0 4px 15px rgba(34,197,94,0.3);
  }

  .reply-box {
    background: linear-gradient(145deg, rgba(25,25,25,0.9) 0%, rgba(15,15,15,0.95) 100%);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(212, 175, 55, 0.25);
    border-radius: 24px;
    padding: 40px;
    box-shadow: 0 20px 50px rgba(0,0,0,0.6), inset 0 1px 0 rgba(255,255,255,0.05);
    margin-top: 40px;
    position: relative;
    overflow: hidden;
  }
  
  .reply-box::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; height: 3px;
    background: var(--gradient-gold);
  }

  .reply-input {
    width: 100%;
    min-height: 150px;
    background: rgba(0,0,0,0.4);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px;
    padding: 24px;
    color: #fff;
    font-size: 16px;
    font-family: inherit;
    line-height: 1.6;
    resize: vertical;
    transition: all 0.3s;
    margin-bottom: 24px;
  }

  .reply-input:focus {
    outline: none;
    border-color: rgba(212,175,55,0.5);
    background: rgba(0,0,0,0.6);
    box-shadow: 0 0 0 4px rgba(212, 175, 55, 0.1);
  }

  .poll-card {
    background: linear-gradient(145deg, rgba(25,25,25,0.8) 0%, rgba(15,15,15,0.9) 100%);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(212, 175, 55, 0.3);
    border-radius: 24px;
    padding: 32px;
    margin-bottom: 40px;
    box-shadow: 0 15px 40px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.05);
    position: relative;
    overflow: hidden;
  }

  .poll-card::before {
    content: '';
    position: absolute;
    top: -50%; right: -50%;
    width: 200px; height: 200px;
    background: var(--gold-300);
    filter: blur(100px);
    opacity: 0.15;
    pointer-events: none;
  }

  .poll-option-bar {
    width: 100%;
    height: 44px;
    background: rgba(0,0,0,0.4);
    border-radius: 12px;
    position: relative;
    overflow: hidden;
    cursor: pointer;
    border: 1px solid rgba(255,255,255,0.08);
    transition: all 0.3s;
  }

  .poll-option-bar:hover {
    border-color: rgba(212,175,55,0.4);
    transform: scale(1.01);
  }

  .poll-option-fill {
    position: absolute;
    top: 0; left: 0; bottom: 0;
    background: linear-gradient(90deg, rgba(212, 175, 55, 0.5) 0%, rgba(245, 208, 97, 0.2) 100%);
    transition: width 1s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @media (max-width: 768px) {
    .premium-entry-card {
      flex-direction: column;
      padding: 24px;
      gap: 20px;
    }
    .entry-author-col {
      width: 100%;
      border-right: none;
      border-bottom: 1px solid rgba(255,255,255,0.06);
      padding-right: 0;
      padding-bottom: 20px;
      flex-direction: row;
      align-items: center;
      gap: 20px;
    }
    .avatar-wrap {
      width: 56px;
      height: 56px;
      margin-bottom: 0;
      font-size: 22px;
    }
    .username {
      text-align: left;
      margin-bottom: 4px;
    }
    .thread-title {
      font-size: 1.8rem;
    }
    .reply-box, .poll-card {
      padding: 24px;
    }
  }
</style>

<div class="thread-hero">
  <div class="thread-header-content">
    <div class="breadcrumb">
      <a href="/forum">Forum</a>
      <span style="opacity: 0.5;">/</span>
      <span><%= thread.category %></span>
    </div>

    <h1 class="thread-title"><%= thread.title %></h1>
    
    <div class="thread-meta-bar">
      <span class="meta-pill highlight">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
        <%= thread.category %>
      </span>
      <span class="meta-pill">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
        <%= thread.entryCount %> Yanıt
      </span>
      <span class="meta-pill">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
        Son aktivite: <%= thread.lastActivity %>
      </span>
      <% if (thread.isHot) { %>
        <span class="meta-pill" style="border-color: rgba(239,68,68,0.5); color: #ef4444; background: rgba(239,68,68,0.1); box-shadow: 0 0 10px rgba(239,68,68,0.2);">
           🔥 Gündemde
        </span>
      <% } %>
    </div>
  </div>
</div>

<div class="entry-container">
  
  <!-- Anket Alanı -->
  <% if (thread.poll) { %>
    <div class="poll-card">
      <h3 style="font-family: var(--font-display); font-size: 22px; color: #fff; margin-bottom: 24px; display: flex; align-items: center; gap: 10px; position: relative; z-index: 1;">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--gold-300)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20v-6M6 20V10M18 20V4"></path></svg>
        Topluluk Anketi
      </h3>
      <div id="poll-container" style="position: relative; z-index: 1;">
        <% thread.poll.options.forEach(opt => { 
             let percent = thread.poll.totalVotes > 0 ? Math.round((opt.votes / thread.poll.totalVotes) * 100) : 0;
        %>
          <div style="margin-bottom: 16px;">
            <div style="display: flex; justify-content: space-between; margin-bottom: 8px; font-size: 15px; font-weight: 600; color: #fff;">
              <span><%= opt.text %></span>
              <span style="color: var(--gold-200);"><%= percent %>% <span style="color: var(--text-muted); font-size: 12px; font-weight: 400; margin-left: 4px;">(<%= opt.votes %> oy)</span></span>
            </div>
            <div class="poll-option-bar" onclick="votePoll('<%= thread.id %>', '<%= opt.id %>')">
              <div class="poll-option-fill" style="width: <%= percent %>%;"></div>
            </div>
          </div>
        <% }); %>
      </div>
      <div style="font-size: 13px; color: var(--text-muted); text-align: right; margin-top: 16px; position: relative; z-index: 1;">Toplam Katılım: <strong style="color: #fff;"><%= thread.poll.totalVotes %></strong></div>
    </div>
  <% } %>

  <% if (entries && entries.length > 0) { %>
    <% entries.forEach((entry, index) => { %>
      <div class="premium-entry-card" id="entry-<%= entry.id %>">
        <div class="entry-author-col">
          <div class="avatar-wrap">
            <a href="/profil/<%= entry.authorUsername %>" style="color: inherit; text-decoration: none;">
              <%= entry.authorUsername.charAt(0).toUpperCase() %>
            </a>
          </div>
          <div>
            <div class="username">
              <a href="/profil/<%= entry.authorUsername %>" style="color: inherit; text-decoration: none;">
                @<%= entry.authorUsername %>
              </a>
            </div>
            <div class="user-badge <%= entry.authorLevel.toLowerCase() %>"><%= entry.authorLevel %></div>
          </div>
        </div>
        
        <div class="entry-content-col">
          <div class="entry-text"><%= entry.content %></div>
          
          <div class="entry-actions">
            <div class="action-time">
              <span><%= entry.createdAt %></span>
              <% if (entry.isThreadStarter) { %>
                <span class="author-tag">Konu Sahibi</span>
              <% } %>
            </div>
            
            <div style="display: flex; align-items: center; gap: 16px;">
              <button class="btn-upvote" onclick="upvoteEntry('<%= thread.id %>', '<%= entry.id %>', this)">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"></polyline></svg>
                <span class="upvote-count"><%= entry.upvotes %></span>
              </button>
              <button class="btn-action" onclick="document.getElementById('reply-area').scrollIntoView({behavior: 'smooth'})">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
                Yanıtla
              </button>
            </div>
          </div>
        </div>
      </div>
    <% }); %>
  <% } else { %>
    <div id="empty-state" style="text-align: center; padding: 80px 20px; background: rgba(20,20,20,0.5); border-radius: 24px; border: 1px dashed rgba(212,175,55,0.2); backdrop-filter: blur(10px);">
      <div style="font-size: 64px; margin-bottom: 24px; animation: float 3s ease-in-out infinite;">💭</div>
      <h3 style="font-family: var(--font-display); font-size: 28px; color: #fff; margin-bottom: 12px; font-weight: 700;">Henüz yanıt yok</h3>
      <p style="color: var(--text-secondary); margin-bottom: 32px; font-size: 16px; max-width: 400px; margin-left: auto; margin-right: auto;">Bu konu hakkında ilk fikri sen belirt ve tartışmayı başlat. Bilgi paylaştıkça büyür.</p>
      <button class="btn btn-gold" onclick="document.getElementById('reply-area').scrollIntoView({behavior: 'smooth'})">İlk Yanıtı Yaz</button>
    </div>
  <% } %>

  <!-- Premium Reply Section -->
  <div class="reply-box" id="reply-area">
    <h3 style="font-family: var(--font-display); font-size: 24px; font-weight: 700; color: #fff; margin-bottom: 24px; display: flex; align-items: center; gap: 12px;">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--gold-200);"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
      Tartışmaya Katıl
    </h3>
    <textarea id="replyContent" class="reply-input" placeholder="Bu konu hakkında ne düşünüyorsunuz? Deneyimlerinizi ve stratejilerinizi paylaşın..."></textarea>
    <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px;">
      <span style="font-size: 13px; color: var(--text-muted); display: flex; align-items: center; gap: 6px;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
        Saygılı ve yapıcı bir dil kullanmaya özen gösterin.
      </span>
      <button class="btn btn-gold" id="submitReplyBtn" style="padding: 14px 36px; font-size: 15px;" onclick="submitReply('<%= thread.id %>')">Yanıtı Gönder</button>
    </div>

    <div id="replyAuthOverlay" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(15,15,15,0.85); backdrop-filter: blur(8px); display: none; align-items: center; justify-content: center; flex-direction: column; gap: 20px; z-index: 10;">
      <div style="width: 60px; height: 60px; border-radius: 50%; background: rgba(212,175,55,0.1); display: flex; align-items: center; justify-content: center; margin-bottom: -10px;">
        <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="var(--gold-200)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
      </div>
      <h4 style="font-family: var(--font-display); color: #fff; font-size: 24px; font-weight: 700; text-align: center;">Yanıt yazmak için giriş yapmalısınız</h4>
      <div style="display: flex; gap: 16px;">
        <a href="/giris" class="btn btn-gold">Giriş Yap</a>
        <a href="/kayit" class="btn btn-outline">Kayıt Ol</a>
      </div>
    </div>
  </div>

</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const user = localStorage.getItem('zengince_user');
    if (!user) {
      document.getElementById('replyAuthOverlay').style.display = 'flex';
      document.getElementById('replyContent').disabled = true;
      document.getElementById('submitReplyBtn').disabled = true;
    }
  });

  async function upvoteEntry(threadId, entryId, btnEl) {
    if (btnEl.classList.contains('active')) return; 
    const user = localStorage.getItem('zengince_user');
    if (!user) {
      if(window.showToast) window.showToast('Oy verebilmek için giriş yapmalısınız.', 'error');
      else alert('Oy verebilmek için giriş yapmalısınız.');
      return;
    }
    
    try {
      const res = await fetch('/api/upvote', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ threadId, entryId })
      });
      const data = await res.json();
      if (data.success) {
        btnEl.classList.add('active');
        btnEl.querySelector('.upvote-count').textContent = data.newUpvotes;
        if(window.showToast) window.showToast('Upvote kaydedildi!', 'success');
      }
    } catch (e) {
      console.error(e);
      if(window.showToast) window.showToast('Oy verilirken hata oluştu.', 'error');
      else alert('Oy verilirken hata oluştu.');
    }
  }

  async function votePoll(threadId, optionId) {
    const user = localStorage.getItem('zengince_user');
    if (!user) {
      if(window.showToast) window.showToast('Oy vermek için giriş yapmalısınız.', 'error');
      else alert('Oy vermek için giriş yapmalısınız.');
      return;
    }

    try {
      const res = await fetch('/api/vote-poll', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ threadId, optionId, username: user })
      });
      const data = await res.json();
      
      if (data.success) {
        if(window.showToast) window.showToast('Oyunuz kaydedildi!', 'success');
        setTimeout(() => window.location.reload(), 800);
      } else {
        if(window.showToast) window.showToast(data.error || 'Hata oluştu', 'error');
        else alert(data.error || 'Hata oluştu');
      }
    } catch(e) {
      console.error(e);
      if(window.showToast) window.showToast('Sunucu hatası.', 'error');
    }
  }

  async function submitReply(threadId) {
    const contentBox = document.getElementById('replyContent');
    const content = contentBox.value.trim();
    const username = localStorage.getItem('zengince_user');

    if (!username) {
      if(window.showToast) window.showToast('Lütfen giriş yapın.', 'error');
      else alert('Lütfen giriş yapın.');
      return;
    }
    if (!content) {
      if(window.showToast) window.showToast('Lütfen bir yanıt yazın.', 'error');
      else alert('Lütfen bir yanıt yazın.');
      return;
    }

    const btn = document.getElementById('submitReplyBtn');
    btn.disabled = true;
    btn.textContent = 'Gönderiliyor...';

    try {
      const res = await fetch('/api/new-entry', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ threadId, content, username })
      });
      const data = await res.json();
      
      if (data.success) {
        if(window.showToast) window.showToast('Yanıtınız başarıyla paylaşıldı!', 'success');
        setTimeout(() => window.location.reload(), 1000);
      } else {
        if(window.showToast) window.showToast(data.error || 'Hata oluştu', 'error');
        else alert(data.error || 'Hata oluştu');
        btn.disabled = false;
        btn.textContent = 'Yanıtı Gönder';
      }
    } catch (e) {
      console.error(e);
      if(window.showToast) window.showToast('Sunucu hatası.', 'error');
      else alert('Sunucu hatası.');
      btn.disabled = false;
      btn.textContent = 'Yanıtı Gönder';
    }
  }
</script>

<%- include('partials/footer') %>
