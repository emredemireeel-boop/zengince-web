
<%- include('partials/header') %>

<style>
  :root {
    --danger-red: #ff3333;
  }
  .makale-hero-danger {
    padding: 100px 0 80px;
    text-align: center;
    position: relative;
    border-bottom: 2px solid var(--danger-red);
  }
  .makale-hero-content {
    position: relative;
    z-index: 2;
  }
  .dropcap.danger {
    color: var(--danger-red) !important;
  }
  .danger-alert {
    background: rgba(255,51,51,0.05) !important;
    border-left: 4px solid var(--danger-red) !important;
  }
  .victim-quotes {
    background: #111;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 8px;
    padding: 30px;
    margin: 40px 0;
  }
  .victim-quotes h3 {
    color: var(--danger-red);
    font-family: 'Outfit', sans-serif;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .quote-item {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.3rem;
    font-style: italic;
    color: #ccc;
    margin-bottom: 15px;
    padding-left: 20px;
    border-left: 2px solid rgba(255,255,255,0.2);
  }
</style>

<main class="makale-detay-page">
  <div class="makale-hero-danger" style="background-image: linear-gradient(to bottom, rgba(10,5,5,0.8) 0%, rgba(10,10,10,1) 100%), url('<%= savunma.kapakGorseli %>'); background-position: center; background-size: cover;">
    <div class="container makale-hero-content">
      <div class="makale-meta">
        <span class="makale-badge" style="background: rgba(255,51,51,0.2); border: 1px solid var(--danger-red); color: #fff; font-weight: bold; padding: 5px 12px; border-radius: 20px; font-size: 0.9rem;">
          <%= savunma.ikon %> Tehlike: <%= savunma.tehlikeSeviyesi %>
        </span>
      </div>
      <h1 class="makale-title" style="margin-top: 20px; font-family: 'Cormorant Garamond', serif; font-size: 3.5rem; color: #fff; text-shadow: 2px 2px 4px rgba(0,0,0,0.8);"><%= savunma.baslik %></h1>
    </div>
  </div>

  <div class="container" style="max-width: 800px; margin: 0 auto; padding: 40px 20px 80px;">
    
    <div class="victim-quotes">
      <h3><i class="fas fa-exclamation-triangle"></i> Mağdurların Ortak İfadeleri</h3>
      <% savunma.magdurIfadeleri.forEach(function(ifade) { %>
        <div class="quote-item">"<%= ifade %>"</div>
      <% }); %>
    </div>

    <div class="makale-content" style="font-family: 'Outfit', sans-serif; font-size: 1.15rem; line-height: 1.8; color: #e0e0e0;">
      <%- savunma.detayliIcerik %>
    </div>
    
    <div class="makale-footer" style="margin-top: 60px; padding-top: 30px; border-top: 1px solid rgba(255,51,51,0.2); text-align: center;">
      <a href="/finansal-savunma" class="btn" style="background: transparent; border: 1px solid var(--danger-red); color: var(--danger-red); padding: 10px 20px; border-radius: 5px; text-decoration: none; transition: all 0.3s ease;">
        &larr; Savunma Merkezine Dön
      </a>
    </div>

  </div>
</main>

<%- include('partials/footer') %>
