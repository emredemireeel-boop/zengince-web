<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Zengince — Zenginlik Eğitim Platformu' %></title>
  <meta name="description" content="<%= typeof desc !== 'undefined' ? desc : 'Zenginlik öğretileri, kitap ve film önerileri ile finansal özgürlük yolculuğunuza başlayın. Zengince.com' %>">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="<%= typeof canonical !== 'undefined' ? canonical : 'https://www.zengince.com' %>">

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:title" content="<%= typeof title !== 'undefined' ? title : 'Zengince — Zenginlik Eğitim Platformu' %>">
  <meta property="og:description" content="<%= typeof desc !== 'undefined' ? desc : 'Zenginlik öğretileri, kitap ve film önerileri ile finansal özgürlük yolculuğunuza başlayın.' %>">
  <meta property="og:url" content="<%= typeof canonical !== 'undefined' ? canonical : 'https://www.zengince.com' %>">
  <meta property="og:site_name" content="Zengince">
  <meta property="og:locale" content="tr_TR">

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= typeof title !== 'undefined' ? title : 'Zengince — Zenginlik Eğitim Platformu' %>">
  <meta name="twitter:description" content="<%= typeof desc !== 'undefined' ? desc : 'Zenginlik öğretileri, kitap ve film önerileri ile finansal özgürlük yolculuğunuza başlayın.' %>">

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">

  <!-- Google Fonts Preconnect -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  <!-- CSS -->
  <link rel="stylesheet" href="/style.css">
</head>
