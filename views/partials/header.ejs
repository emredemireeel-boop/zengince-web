<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Zengince — Zenginlik Eğitim Platformu' %></title>
  <meta name="description" content="<%= typeof desc !== 'undefined' ? desc : 'Zenginlik öğretileri, kitap ve film önerileri ile finansal özgürlük yolculuğunuza başlayın. Zengince.com' %>">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="<%= typeof canonical !== 'undefined' ? canonical : 'https://www.zengince.com' %>">

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:title" content="<%= typeof title !== 'undefined' ? title : 'Zengince — Zenginlik Eğitim Platformu' %>">
  <meta property="og:description" content="<%= typeof desc !== 'undefined' ? desc : 'Zenginlik öğretileri, kitap ve film önerileri ile finansal özgürlük yolculuğunuza başlayın.' %>">
  <meta property="og:url" content="<%= typeof canonical !== 'undefined' ? canonical : 'https://www.zengince.com' %>">
  <meta property="og:site_name" content="Zengince">
  <meta property="og:locale" content="tr_TR">

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= typeof title !== 'undefined' ? title : 'Zengince — Zenginlik Eğitim Platformu' %>">
  <meta name="twitter:description" content="<%= typeof desc !== 'undefined' ? desc : 'Zenginlik öğretileri, kitap ve film önerileri ile finansal özgürlük yolculuğunuza başlayın.' %>">

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">

  <!-- Google Fonts Preconnect -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  <!-- CSS -->
  <link rel="stylesheet" href="/style.css">

  <!-- Firebase -->
  <script type="module" src="/firebase-config.js"></script>
</head>
<body>
  <!-- ── Navbar ────────────────────────────────────────────────────────── -->
  <header class="navbar" id="navbar">
    <div class="container">
      <a href="/" class="navbar-brand">
        <span class="z-icon">Z</span>
        <span>Zengin<span style="color: var(--gold-400);">ce</span></span>
      </a>
      <nav class="navbar-nav" id="navMenu">
        <a href="/" class="<%= typeof path !== 'undefined' && path === '/' ? 'active' : '' %>">Ana Sayfa</a>
        <a href="/forum" class="<%= typeof path !== 'undefined' && path === '/forum' ? 'active' : '' %>">Forum</a>
        
        <div class="nav-dropdown">
          <a href="#" class="nav-dropbtn">Kütüphane ▾</a>
          <div class="nav-dropdown-content">
            <a href="/makaleler">Makaleler (Blog)</a>
            <a href="/kitaplar">Kitaplar</a>
            <a href="/filmler">Filmler</a>
            <a href="/belgeseller">Belgeseller</a>
            <a href="/diziler">Diziler</a>
            <a href="/podcastler">Podcastler</a>
          </div>
        </div>

        <div class="nav-dropdown">
          <a href="#" class="nav-dropbtn">Bilgelik ▾</a>
          <div class="nav-dropdown-content">
            <a href="/tasarruf-modelleri">Tasarruf & Bütçe</a>
            <a href="/yatirim-araclari">Yatırım Araçları (101)</a>
            <a href="/ogretiler">Temel Öğretiler</a>
            <a href="/girisimciler">Usta Girişimciler</a>
            <a href="/deha-hamleleri">Deha Hamleleri</a>
            <a href="/aliskanliklar">Alışkanlıklar</a>
            <a href="/alintilar">Altın Sözler</a>
            <a href="/finansal-savunma">Finansal Savunma</a>
            <a href="/iflaslar">İflaslar & Hatalar</a>
          </div>
        </div>

        <a href="/sozluk" class="<%= typeof path !== 'undefined' && path === '/sozluk' ? 'active' : '' %>">Sözlük</a>

        <div class="nav-dropdown">
          <a href="#" class="nav-dropbtn">Hesaplamalar ▾</a>
          <div class="nav-dropdown-content">
            <a href="/kdv-hesaplayici">KDV Hesaplama</a>
            <a href="/yuzde-hesaplayici">Yüzde Hesaplama</a>
            <a href="/hesaplayici">Bileşik Getiri</a>
            <a href="/kredi-hesaplayici">Kredi Maliyeti</a>
            <a href="/ticaret-hesaplayici">E-Ticaret Kârı</a>
            <a href="/kidem-tazminati-hesaplayici">Kıdem Tazminatı</a>
            <a href="/kira-artisi-hesaplayici">Kira Artışı (TÜFE)</a>
            <a href="/mevduat-hesaplayici">Mevduat & Reel Getiri</a>
            <a href="/butce-hesaplayici">Gelir Gider Dengesi</a>
            <a href="/saatlik-ucret-hesaplayici">Gerçek Saatlik Ücret</a>
            <a href="/aliskanlik-maliyeti">Alışkanlık Maliyeti</a>
            <a href="/sigara-alkol-hesaplayici">Sigara ve Alkol Zehri</a>
            <a href="/fire-hesaplayici">Özgürlük (FIRE)</a>
            <a href="/temettu-hesaplayici">Temettü Emekliliği</a>
          </div>
        </div>
      </nav>

      <div class="auth-buttons">
        <div id="auth-guest" style="display: flex; gap: 8px; align-items: center;">
          <a href="/giris" class="btn" style="background: transparent; border: 1px solid var(--card-border); color: var(--foreground); padding: 6px 12px; font-size: 13px;">Giriş Yap</a>
          <a href="/kayit" class="btn btn-gold" style="padding: 6px 12px; font-size: 13px;">Kayıt Ol</a>
        </div>
        <div id="auth-user" style="display: none; gap: 12px; align-items: center;">
          <a href="/mesajlar" class="btn" style="background: transparent; border: none; color: #fff; display: flex; align-items: center; gap: 4px; padding: 6px; font-size: 13px;" title="Mesajlar">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
          </a>
          <a id="btn-profile" href="#" class="btn" style="background: transparent; border: 1px solid var(--gold-200); color: var(--gold-200); display: flex; align-items: center; gap: 6px; padding: 6px 12px; font-size: 13px;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
            <span id="header-username" style="max-width: 100px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">Profil</span>
          </a>
          <button onclick="logout()" style="background: transparent; border: none; color: var(--text-muted); cursor: pointer; text-decoration: underline; font-size: 13px; padding: 0;">Çıkış</button>
        </div>
      </div>

      <button class="navbar-toggle" id="navToggle" aria-label="Menüyü aç">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </header>

  <script>
    function checkAuth() {
      const user = localStorage.getItem('zengince_user');
      const guestDiv = document.getElementById('auth-guest');
      const userDiv = document.getElementById('auth-user');
      const profileBtn = document.getElementById('btn-profile');
      const headerUsername = document.getElementById('header-username');

      if (user) {
        if(guestDiv) guestDiv.style.display = 'none';
        if(userDiv) userDiv.style.display = 'flex';
        if(headerUsername) headerUsername.textContent = user;
        if(profileBtn) profileBtn.href = '/profil/' + user;
      } else {
        if(guestDiv) guestDiv.style.display = 'flex';
        if(userDiv) userDiv.style.display = 'none';
      }
    }

    function logout() {
      localStorage.removeItem('zengince_user');
      window.location.reload();
    }

    // Header script
    document.addEventListener('DOMContentLoaded', checkAuth);
    checkAuth(); // hemen çalıştır (flash engellemek için)
  </script>
