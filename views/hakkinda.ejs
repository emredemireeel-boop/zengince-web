<%- include('partials/header') %>

  <!-- About Hero -->
  <section class="about-hero">
    <div class="container">
      <span class="section-badge">✦ Misyonumuz</span>
      <h1 class="section-title" style="margin-top:12px;">Zengince <span class="gold">Hakkında</span></h1>
      <p class="section-desc" style="margin:12px auto 0;">Finansal okuryazarlığı herkes için erişilebilir kılma misyonumuz</p>
    </div>
  </section>

  <!-- About Content -->
  <section class="section">
    <div class="container">
      <div class="about-content reveal">
        <p class="about-text">
          <strong style="color:var(--gold-200);">Zengince</strong>, zenginliğin sadece para değil, aynı zamanda bir 
          <em>zihniyet</em>, bir <em>yaşam felsefesi</em> ve bir <em>alışkanlık sistemi</em> olduğuna inanan bir 
          eğitim platformudur.
        </p>
        <p class="about-text">
          Amacımız; dünyaca ünlü yatırımcıların, girişimcilerin ve düşünürlerin zenginlik üzerine bilgeliklerini 
          Türkçe olarak derlemeye, en etkili kitap ve film önerilerini sunmaya ve kanıtlanmış zenginlik alışkanlıklarını 
          herkesin hayatına entegre etmesine yardımcı olmaktır.
        </p>
        <p class="about-text">
          Warren Buffett'ın "hayatımda en iyi yatırım, kendime yaptığım yatırımdı" sözünden ilham alarak, 
          <strong style="color:var(--white);">bilgi ve bilinçle donanmış bireylerin</strong> finansal özgürlüğe 
          ulaşabileceğine inanıyoruz.
        </p>
      </div>

      <!-- Values -->
      <div class="about-values stagger-children" style="margin-top:60px;">
        <div class="about-value-card">
          <span class="about-value-icon">🧠</span>
          <h3 class="about-value-title">Zihniyet Dönüşümü</h3>
          <p class="about-value-text">Zenginlik önce zihinde başlar. Para hakkındaki inançlarınızı değiştirerek finansal dönüşümünüzü tetikliyoruz.</p>
        </div>
        <div class="about-value-card">
          <span class="about-value-icon">📚</span>
          <h3 class="about-value-title">Bilgiyle Donanma</h3>
          <p class="about-value-text">Dünyanın en başarılı insanlarının deneyimlerini, kitaplar ve filmler aracılığıyla Türkçe olarak sunuyoruz.</p>
        </div>
        <div class="about-value-card">
          <span class="about-value-icon">⚡</span>
          <h3 class="about-value-title">Eyleme Geçirme</h3>
          <p class="about-value-text">Bilgi tek başına yetmez. Kanıtlanmış alışkanlıklar ve pratik stratejilerle bilgiyi eyleme dönüştürüyoruz.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Quote Section -->
  <section class="section section--alt">
    <div class="container">
      <div class="reveal" style="text-align:center;max-width:700px;margin:0 auto;">
        <span style="font-size:4rem;display:block;margin-bottom:24px;">💎</span>
        <p style="font-family:var(--font-display);font-size:1.4rem;font-style:italic;color:var(--text-primary);line-height:1.6;margin-bottom:20px;">
          "Bir yatırımın en iyi getirisi, bilgiye yapılan yatırımdır."
        </p>
        <p style="color:var(--gold-300);font-weight:600;">— Benjamin Franklin</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container reveal">
      <h2 class="cta-title">Yolculuğunuza <span class="gold">Başlayın</span></h2>
      <p class="cta-desc">Zenginlik eğitim içeriklerimizi keşfedin ve finansal özgürlük yolculuğunuza ilk adımı atın.</p>
      <div class="hero-actions">
        <a href="/ogretiler" class="btn btn-gold">Öğretilere Başla ✦</a>
        <a href="/kitaplar" class="btn btn-outline">Kitaplara Göz At →</a>
      </div>
    </div>
  </section>

<%- include('partials/footer') %>
