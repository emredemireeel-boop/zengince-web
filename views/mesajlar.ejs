<%- include('partials/header') %>

<style>
  body {
    background-color: var(--background);
  }

  .dm-page-wrapper {
    padding: 100px 20px 40px;
    min-height: calc(100vh - 80px);
    display: flex;
    justify-content: center;
  }

  .dm-container {
    width: 100%;
    max-width: 1200px;
    height: 75vh;
    background: rgba(15, 15, 15, 0.6);
    backdrop-filter: blur(25px);
    -webkit-backdrop-filter: blur(25px);
    border: 1px solid rgba(212, 175, 55, 0.2);
    border-radius: 20px;
    display: flex;
    overflow: hidden;
    box-shadow: 0 20px 50px rgba(0,0,0,0.5), inset 0 0 0 1px rgba(255,255,255,0.05);
  }

  /* SIDEBAR (SOL TARAF) */
  .dm-sidebar {
    width: 320px;
    border-right: 1px solid rgba(212, 175, 55, 0.15);
    display: flex;
    flex-direction: column;
    background: rgba(0, 0, 0, 0.2);
  }

  .dm-sidebar-header {
    padding: 20px;
    border-bottom: 1px solid rgba(212, 175, 55, 0.15);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .dm-sidebar-header h2 {
    font-size: 1.2rem;
    color: var(--gold-200);
    margin: 0;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .dm-conversation-list {
    flex: 1;
    overflow-y: auto;
    padding: 10px 0;
  }

  .dm-conversation-list::-webkit-scrollbar { width: 6px; }
  .dm-conversation-list::-webkit-scrollbar-thumb { background: rgba(212, 175, 55, 0.3); border-radius: 10px; }

  .dm-chat-item {
    padding: 15px 20px;
    display: flex;
    align-items: center;
    gap: 12px;
    cursor: pointer;
    transition: all 0.3s ease;
    border-left: 3px solid transparent;
  }

  .dm-chat-item:hover {
    background: rgba(255, 255, 255, 0.03);
  }

  .dm-chat-item.active {
    background: rgba(212, 175, 55, 0.08);
    border-left-color: var(--gold-300);
  }

  .dm-avatar {
    width: 45px;
    height: 45px;
    border-radius: 50%;
    background: linear-gradient(135deg, #2a2a2a, #1a1a1a);
    border: 1px solid var(--gold-400);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    color: var(--gold-200);
    font-size: 1.2rem;
    flex-shrink: 0;
  }

  .dm-chat-item.active .dm-avatar {
    background: linear-gradient(135deg, var(--gold-400), var(--gold-200));
    color: #000;
    border-color: transparent;
  }

  .dm-chat-info {
    flex: 1;
    overflow: hidden;
  }

  .dm-chat-name {
    font-weight: 600;
    color: #fff;
    margin-bottom: 4px;
    font-size: 1rem;
    display: flex;
    justify-content: space-between;
  }

  .dm-chat-time {
    font-size: 0.75rem;
    color: var(--text-muted);
    font-weight: normal;
  }

  .dm-chat-preview {
    font-size: 0.85rem;
    color: var(--text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* MAIN CHAT AREA (SAĞ TARAF) */
  .dm-main {
    flex: 1;
    display: flex;
    flex-direction: column;
    position: relative;
    background: radial-gradient(circle at center, rgba(212, 175, 55, 0.02) 0%, transparent 70%);
  }

  .dm-chat-header {
    padding: 20px 25px;
    border-bottom: 1px solid rgba(212, 175, 55, 0.15);
    display: none; /* Initially hidden */
    align-items: center;
    justify-content: space-between;
    background: rgba(0, 0, 0, 0.3);
  }

  .dm-header-user {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .dm-header-user .dm-avatar {
    width: 40px; height: 40px; font-size: 1rem;
  }

  .dm-header-name {
    font-size: 1.1rem;
    font-weight: bold;
    color: #fff;
  }

  .dm-header-status {
    font-size: 0.8rem;
    color: var(--emerald);
    display: flex;
    align-items: center;
    gap: 5px;
  }
  .dm-header-status::before {
    content: ''; width: 8px; height: 8px; background: var(--emerald); border-radius: 50%; box-shadow: 0 0 5px var(--emerald);
  }

  .dm-messages-area {
    flex: 1;
    padding: 25px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 15px;
  }
  
  .dm-messages-area::-webkit-scrollbar { width: 6px; }
  .dm-messages-area::-webkit-scrollbar-thumb { background: rgba(212, 175, 55, 0.3); border-radius: 10px; }

  .msg-bubble-container {
    display: flex;
    flex-direction: column;
    max-width: 75%;
    animation: fadeInUp 0.3s ease forwards;
  }

  .msg-me {
    align-self: flex-end;
    align-items: flex-end;
  }

  .msg-other {
    align-self: flex-start;
    align-items: flex-start;
  }

  .msg-bubble {
    padding: 12px 18px;
    border-radius: 20px;
    font-size: 0.95rem;
    line-height: 1.5;
    word-break: break-word;
    position: relative;
  }

  .msg-me .msg-bubble {
    background: linear-gradient(135deg, var(--gold-300), var(--gold-400));
    color: #000;
    border-bottom-right-radius: 4px;
    box-shadow: 0 4px 15px rgba(212, 175, 55, 0.2);
  }

  .msg-other .msg-bubble {
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    border-bottom-left-radius: 4px;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .msg-time {
    font-size: 0.7rem;
    color: var(--text-muted);
    margin-top: 5px;
    padding: 0 5px;
  }

  .dm-input-area {
    padding: 20px 25px;
    border-top: 1px solid rgba(212, 175, 55, 0.15);
    display: none; /* Initially hidden */
    background: rgba(0, 0, 0, 0.3);
  }

  .dm-input-wrapper {
    display: flex;
    align-items: center;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 30px;
    padding: 5px 5px 5px 20px;
    transition: border-color 0.3s, box-shadow 0.3s;
  }

  .dm-input-wrapper:focus-within {
    border-color: var(--gold-300);
    box-shadow: 0 0 15px rgba(212, 175, 55, 0.1);
  }

  .dm-input-wrapper input {
    flex: 1;
    background: transparent;
    border: none;
    color: #fff;
    font-size: 1rem;
    outline: none;
  }

  .dm-input-wrapper input::placeholder {
    color: var(--text-muted);
  }

  .dm-send-btn {
    background: var(--gradient-gold);
    border: none;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #000;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .dm-send-btn:hover {
    transform: scale(1.1);
    box-shadow: 0 0 15px rgba(212, 175, 55, 0.5);
  }

  .dm-send-btn svg {
    width: 18px; height: 18px;
    margin-left: 2px;
  }

  .dm-empty-state {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
    text-align: center;
    padding: 20px;
  }

  .dm-empty-state svg {
    width: 60px; height: 60px;
    color: rgba(212, 175, 55, 0.3);
    margin-bottom: 20px;
  }

  .dm-empty-state h3 {
    color: #fff;
    font-size: 1.5rem;
    margin-bottom: 10px;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 768px) {
    .dm-container { flex-direction: column; height: 85vh; border-radius: 0; border: none; border-top: 1px solid rgba(212,175,55,0.2); }
    .dm-page-wrapper { padding: 60px 0 0 0; }
    .dm-sidebar { width: 100%; height: 35%; border-right: none; border-bottom: 1px solid rgba(212, 175, 55, 0.15); }
    .dm-main { height: 65%; }
  }
</style>

<div class="dm-page-wrapper">
  <div class="dm-container">
    
    <!-- Sidebar -->
    <div class="dm-sidebar">
      <div class="dm-sidebar-header">
        <h2>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
          Mesajlar
        </h2>
      </div>
      <div class="dm-conversation-list" id="conversation-list">
        <!-- Sohbetler JS ile yüklenecek -->
        <div style="padding: 20px; text-align: center; color: var(--text-muted); font-size: 0.9rem;">
          Yükleniyor...
        </div>
      </div>
    </div>

    <!-- Main Chat -->
    <div class="dm-main">
      
      <!-- Empty State -->
      <div class="dm-empty-state" id="chat-empty">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
        <h3>Sohbet Seçin</h3>
        <p>Mesajlaşmaya başlamak için sol taraftan bir kişi seçin<br>veya forum üzerinden birinin profiline giderek mesaj atın.</p>
      </div>

      <!-- Chat Header -->
      <div class="dm-chat-header" id="chat-header">
        <div class="dm-header-user">
          <div class="dm-avatar" id="header-avatar">?</div>
          <div>
            <div class="dm-header-name" id="header-name">Kullanıcı</div>
            <div class="dm-header-status">Çevrimiçi</div>
          </div>
        </div>
        <a href="#" id="header-profile-link" class="btn" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); padding: 6px 12px; font-size: 0.85rem;">Profili Gör</a>
      </div>

      <!-- Messages Area -->
      <div class="dm-messages-area" id="chat-window">
        <!-- Mesajlar JS ile yüklenecek -->
      </div>

      <!-- Input Area -->
      <div class="dm-input-area" id="chat-input-area">
        <div class="dm-input-wrapper">
          <input type="text" id="chat-input" placeholder="Bir mesaj yazın..." autocomplete="off">
          <button class="dm-send-btn" onclick="sendMessage()" title="Gönder">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
          </button>
        </div>
      </div>

    </div>
  </div>
</div>

<script>
  const currentUser = localStorage.getItem('zengince_user');
  let activeChatUser = '<%= toUser %>';
  let conversations = {};

  if (!currentUser) {
    document.body.innerHTML = '<div style="height:100vh; display:flex; align-items:center; justify-content:center; color:#fff; font-size:1.5rem;">Giriş yapmalısınız. Yönlendiriliyorsunuz...</div>';
    setTimeout(() => window.location.href = '/giris', 1500);
  } else {
    loadMessages();
    setInterval(loadMessages, 3000);
  }

  function formatTime(timestamp) {
    const d = new Date(timestamp);
    const today = new Date();
    const isToday = d.getDate() === today.getDate() && d.getMonth() === today.getMonth() && d.getFullYear() === today.getFullYear();
    
    let hours = d.getHours().toString().padStart(2, '0');
    let mins = d.getMinutes().toString().padStart(2, '0');
    
    if (isToday) {
      return `${hours}:${mins}`;
    } else {
      let day = d.getDate().toString().padStart(2, '0');
      let month = (d.getMonth() + 1).toString().padStart(2, '0');
      return `${day}.${month}.${d.getFullYear()} ${hours}:${mins}`;
    }
  }

  async function loadMessages() {
    try {
      const res = await fetch('/api/messages/' + currentUser);
      const data = await res.json();
      if(data.success) {
        const oldLength = JSON.stringify(conversations).length;
        conversations = data.conversations;
        
        if (activeChatUser && !conversations[activeChatUser]) {
          conversations[activeChatUser] = [];
        }

        const newLength = JSON.stringify(conversations).length;
        if (oldLength !== newLength) {
          renderConversationList();
          if (activeChatUser) renderChat(activeChatUser);
        } else if (document.getElementById('conversation-list').children.length === 0 || document.getElementById('conversation-list').innerHTML.includes('Yükleniyor')) {
          renderConversationList();
          if (activeChatUser) renderChat(activeChatUser);
        }
      }
    } catch(e) {
      console.error(e);
    }
  }

  function renderConversationList() {
    const listEl = document.getElementById('conversation-list');
    listEl.innerHTML = '';
    
    const sortedUsers = Object.keys(conversations).sort((a,b) => {
      const lastMsgA = conversations[a][conversations[a].length-1];
      const lastMsgB = conversations[b][conversations[b].length-1];
      const timeA = lastMsgA ? lastMsgA.date : 0;
      const timeB = lastMsgB ? lastMsgB.date : 0;
      return timeB - timeA;
    });

    if (sortedUsers.length === 0) {
      listEl.innerHTML = '<div style="padding: 30px 20px; text-align: center; color: var(--text-muted); font-size: 0.95rem;">Henüz hiç sohbetiniz yok. Forumda birinin profiline girerek ilk mesajınızı gönderin.</div>';
      return;
    }

    sortedUsers.forEach(user => {
      const msgs = conversations[user];
      const lastMsgObj = msgs.length > 0 ? msgs[msgs.length-1] : null;
      const lastMsgText = lastMsgObj ? lastMsgObj.text : 'Sohbete başla...';
      const lastMsgTime = lastMsgObj ? formatTime(lastMsgObj.date) : '';
      const initial = user.charAt(0).toUpperCase();

      const div = document.createElement('div');
      div.className = `dm-chat-item ${activeChatUser === user ? 'active' : ''}`;
      
      div.innerHTML = `
        <div class="dm-avatar">${initial}</div>
        <div class="dm-chat-info">
          <div class="dm-chat-name">
            <span>@${user}</span>
            <span class="dm-chat-time">${lastMsgTime}</span>
          </div>
          <div class="dm-chat-preview">${lastMsgText}</div>
        </div>
      `;
      
      div.onclick = () => {
        activeChatUser = user;
        renderConversationList();
        renderChat(user);
      };
      
      listEl.appendChild(div);
    });
  }

  function renderChat(user) {
    document.getElementById('chat-empty').style.display = 'none';
    document.getElementById('chat-header').style.display = 'flex';
    document.getElementById('chat-input-area').style.display = 'block';
    
    document.getElementById('header-name').innerText = '@' + user;
    document.getElementById('header-avatar').innerText = user.charAt(0).toUpperCase();
    document.getElementById('header-profile-link').href = '/profil/' + user;
    
    const msgs = conversations[user] || [];
    const windowEl = document.getElementById('chat-window');
    
    const isAtBottom = windowEl.scrollHeight - windowEl.scrollTop <= windowEl.clientHeight + 50;

    windowEl.innerHTML = '';
    
    if (msgs.length === 0) {
      windowEl.innerHTML = '<div style="text-align:center; color:var(--text-muted); margin-top: 20px; font-size: 0.9rem;">Burası çok sessiz. İlk mesajı siz gönderin!</div>';
    }

    msgs.forEach(m => {
      const isMe = m.from === currentUser;
      const bubble = document.createElement('div');
      bubble.className = `msg-bubble-container ${isMe ? 'msg-me' : 'msg-other'}`;
      
      const timeStr = formatTime(m.date);

      bubble.innerHTML = `
        <div class="msg-bubble">${m.text}</div>
        <div class="msg-time">${timeStr}</div>
      `;
      
      windowEl.appendChild(bubble);
    });
    
    if (isAtBottom || msgs.length > 0) {
      setTimeout(() => {
        windowEl.scrollTop = windowEl.scrollHeight;
      }, 50);
    }
  }

  async function sendMessage() {
    const input = document.getElementById('chat-input');
    const text = input.value.trim();
    if (!text || !activeChatUser) return;

    input.value = '';
    
    try {
      const res = await fetch('/api/send-message', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ from: currentUser, to: activeChatUser, text })
      });
      const data = await res.json();
      if(data.success) {
        if(!conversations[activeChatUser]) conversations[activeChatUser] = [];
        conversations[activeChatUser].push(data.message);
        renderConversationList();
        renderChat(activeChatUser);
      }
    } catch(e) {
      console.error(e);
      alert('Mesaj gönderilemedi.');
    }
  }

  document.getElementById('chat-input').addEventListener('keypress', function (e) {
    if (e.key === 'Enter') {
      sendMessage();
    }
  });
</script>

<%- include('partials/footer') %>
