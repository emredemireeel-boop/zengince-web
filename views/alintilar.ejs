<%- include('partials/header') %>

  <!-- Page Header -->
  <section class="page-header">
    <div class="container">
      <span class="section-badge">💎 Bilgelik Hazinesi</span>
      <h1 class="section-title" style="margin-top:12px;">Altın <span class="gold">Sözler</span></h1>
      <p class="section-desc" style="margin:8px auto 0;">Dünyanın en başarılı insanlarından ilham verici zenginlik alıntıları</p>
    </div>
  </section>

  <!-- Alıntılar Section -->
  <section class="section">
    <div class="container">
      <!-- Filter Bar -->
      <div class="filter-bar reveal">
        <button class="filter-btn active" data-filter="tumu">✦ Tümü</button>
        <% Object.keys(kategoriler).forEach(function(key) { %>
        <button class="filter-btn" data-filter="<%= key %>"><%= kategoriler[key].emoji %> <%= kategoriler[key].baslik %></button>
        <% }); %>
      </div>

      <!-- Quotes Grid -->
      <div class="grid-3 stagger-children" id="alintilar-grid">
        <% alintilar.forEach(function(a) { %>
        <div class="quote-card" data-kategori="<%= a.kategori %>">
          <p class="quote-card-text">"<%= a.soz %>"</p>
          <div class="quote-card-author">
            <span class="quote-card-avatar"><%= a.emoji %></span>
            <div>
              <p class="quote-card-name"><%= a.kisi %></p>
              <p class="quote-card-unvan"><%= a.unvan %></p>
            </div>
          </div>
        </div>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container reveal">
      <h2 class="cta-title">Sözlerden <span class="gold">Eyleme</span> Geçin</h2>
      <p class="cta-desc">İlham almak güzel ama yetmez. Zenginlik alışkanlıklarını hayatınıza entegre edin.</p>
      <a href="/aliskanliklar" class="btn btn-gold">Alışkanlıkları Keşfet ✦</a>
    </div>
  </section>

<%- include('partials/footer') %>
