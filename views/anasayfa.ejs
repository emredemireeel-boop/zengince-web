<%- include('partials/header') %>

<style>
  .hero-section {
    position: relative;
    padding: 100px 20px;
    text-align: center;
    overflow: hidden;
    min-height: 80vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }
  .hero-bg {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(212, 175, 55, 0.15) 0%, rgba(0,0,0,0) 70%);
    z-index: 0;
  }
  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 800px;
  }
  .hero-title {
    font-size: 56px;
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: 24px;
    color: #fff;
  }
  .hero-title span {
    color: var(--gold-300);
  }
  .hero-desc {
    font-size: 20px;
    color: var(--text-muted);
    margin-bottom: 40px;
    line-height: 1.6;
  }
  .hero-buttons {
    display: flex;
    gap: 16px;
    justify-content: center;
  }
  .hero-btn {
    padding: 16px 32px;
    font-size: 18px;
    font-weight: 800;
    border-radius: 12px;
    text-decoration: none;
    transition: all 0.3s;
  }
  .hero-btn-primary {
    background: linear-gradient(135deg, var(--gold-200), var(--gold-400));
    color: #111;
    box-shadow: 0 10px 20px rgba(212, 175, 55, 0.3);
  }
  .hero-btn-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 15px 30px rgba(212, 175, 55, 0.4);
  }
  .hero-btn-secondary {
    background: rgba(255,255,255,0.05);
    color: #fff;
    border: 1px solid rgba(255,255,255,0.1);
    backdrop-filter: blur(10px);
  }
  .hero-btn-secondary:hover {
    background: rgba(255,255,255,0.1);
    transform: translateY(-3px);
  }
  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
    margin-top: 80px;
    width: 100%;
    max-width: 1200px;
  }
  .feature-card {
    background: rgba(20, 20, 20, 0.6);
    border: 1px solid rgba(212, 175, 55, 0.1);
    padding: 32px;
    border-radius: 20px;
    text-align: left;
    transition: transform 0.3s;
    backdrop-filter: blur(10px);
  }
  .feature-card:hover {
    transform: translateY(-5px);
    border-color: rgba(212, 175, 55, 0.3);
  }
  .feature-icon {
    font-size: 32px;
    margin-bottom: 20px;
    display: inline-block;
    background: rgba(212, 175, 55, 0.1);
    padding: 16px;
    border-radius: 16px;
    color: var(--gold-200);
  }
  .feature-title {
    font-size: 22px;
    font-weight: 700;
    color: #fff;
    margin-bottom: 12px;
  }
  .feature-desc {
    color: var(--text-muted);
    line-height: 1.5;
  }
</style>

<div class="hero-section">
  <div class="hero-bg"></div>
  <div class="hero-content">
    <h1 class="hero-title">Finansal Özgürlüğe <br><span>İlk Adımınızı Atın</span></h1>
    <p class="hero-desc">Borsa, yatırım stratejileri, zenginlik öğretileri ve binlerce yatırımcının deneyimlerini paylaştığı Türkiye'nin premium finans topluluğu.</p>
    
    <div class="hero-buttons">
      <a href="/forum" class="hero-btn hero-btn-primary">Foruma Katıl</a>
      <a href="/ogretiler" class="hero-btn hero-btn-secondary">Öğretileri Keşfet</a>
    </div>

    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon">📈</div>
        <h3 class="feature-title">Topluluk Odaklı Forum</h3>
        <p class="feature-desc">Diğer yatırımcılarla fikir alışverişi yapın, stratejilerinizi tartışın ve yeni fırsatları ilk siz keşfedin.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">📚</div>
        <h3 class="feature-title">Premium Kütüphane</h3>
        <p class="feature-desc">Milyonerlerin zihin yapısını anlamak için özenle seçilmiş kitap, film ve belgesel arşivimize göz atın.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🧮</div>
        <h3 class="feature-title">Akıllı Hesaplayıcılar</h3>
        <p class="feature-desc">Bileşik getiri, enflasyon, FIRE ve gerçek saatlik ücretinizi hesaplayarak hedeflerinize netlik kazandırın.</p>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
