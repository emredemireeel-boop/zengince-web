<%- include('partials/header') %>

  <!-- Page Header -->
  <section class="page-header">
    <div class="container">
      <span class="section-badge">🧠 Liderlerin Zihin Yapısı</span>
      <h1 class="section-title" style="margin-top:12px;">Usta <span class="gold">Girişimciler</span></h1>
      <p class="section-desc" style="margin:8px auto 0;">Dünyayı değiştiren milyarderlerin mental modelleri ve karar verme mekanizmaları</p>
    </div>
  </section>

  <!-- Girişimciler Section -->
  <section class="section">
    <div class="container">

      <!-- Entrepreneurs Grid -->
      <div class="grid-2 stagger-children">
        <% girisimciler.forEach(function(g) { %>
        <a href="/girisimciler/<%= g.slug %>" class="card" style="text-decoration: none; display: flex; flex-direction: column; height: 100%; padding: 0; overflow: hidden; transition: transform 0.3s ease, box-shadow 0.3s ease;" onmouseover="this.style.transform='translateY(-5px)'; this.style.boxShadow='var(--shadow-gold)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='var(--shadow-md)';">
          
          <!-- Card Header (Visual) -->
          <div style="padding: 40px 32px; background: linear-gradient(135deg, rgba(212,175,55,0.05) 0%, var(--dark-700) 100%); border-bottom: 1px solid rgba(255,255,255,0.05); text-align: center; flex-shrink: 0;">
            <div style="width: 120px; height: 120px; margin: 0 auto 16px; border-radius: 50%; overflow: hidden; border: 3px solid var(--gold-300); box-shadow: 0 8px 24px rgba(212,175,55,0.2);">
              <img src="<%= g.foto %>" alt="<%= g.isim %>" style="width: 100%; height: 100%; object-fit: cover; object-position: top center; background-color: var(--dark-800);">
            </div>
            <h2 class="card-title" style="font-size: 1.8rem; color: var(--white);"><%= g.isim %></h2>
            <p style="color: var(--gold-300); font-weight: 500; font-size: 0.95rem; margin-bottom: 8px;"><%= g.unvan %></p>
            <div style="display: inline-block; background: var(--gradient-gold); color: var(--dark-900); font-weight: 700; padding: 4px 12px; border-radius: 100px; font-size: 0.85rem;">
              Net Değer: <%= g.netDeger %>
            </div>
          </div>

          <!-- Card Body -->
          <div style="padding: 32px; display: flex; flex-direction: column; flex-grow: 1;">
            <p style="color: var(--text-100); line-height: 1.7; font-size: 1rem; margin-bottom: 24px; flex-grow: 1;">
              <%= g.ozet %>
            </p>

            <div style="background: rgba(255,255,255,0.03); padding: 20px; border-radius: var(--radius-md); border: 1px solid rgba(212,175,55,0.1); margin-bottom: 24px;">
              <p style="font-style: italic; color: var(--gold-200); font-size: 1.05rem; line-height: 1.6; font-family: var(--font-display); text-align: center;">
                "<%= g.altinSoz %>"
              </p>
            </div>
            
            <div style="margin-top: auto; padding-top: 16px; border-top: 1px solid var(--glass-border); font-size: 0.95rem; color: var(--gold-200); font-weight: 600; display: flex; justify-content: center; align-items: center; gap: 6px;">
              Tüm Zihin Modellerini İncele <span style="font-size: 1.2rem;">→</span>
            </div>
          </div>
        </a>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container reveal">
      <h2 class="cta-title">Ustaların <span class="gold">İzinden Gidin</span></h2>
      <p class="cta-desc">Eğer onların düşündüğü gibi düşünürseniz, eninde sonunda onların elde ettiği sonuçları elde edersiniz.</p>
      <a href="/ogretiler" class="btn btn-gold">Öğretileri Keşfet ✦</a>
    </div>
  </section>

<%- include('partials/footer') %>
