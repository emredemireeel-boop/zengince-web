<%- include('partials/header') %>

  <!-- Page Header -->
  <section class="page-header" style="padding-bottom: 40px;">
    <div class="container">
      <span class="section-badge">📚 Finansal Okuryazarlık</span>
      <h1 class="section-title" style="margin-top:12px;">Finansal <span class="gold">Sözlük</span></h1>
      <p class="section-desc" style="margin:8px auto 0;">Zenginlerin dilini anlamadan zenginlerin dünyasına giremezsiniz. Temel kavramları basitçe öğrenin.</p>
    </div>
  </section>

  <!-- Glossary Section -->
  <section class="section" style="padding-top: 0;">
    <div class="container">
      
      <!-- Arama Çubuğu -->
      <div style="margin-bottom: 24px; max-width: 600px; margin-left: auto; margin-right: auto;">
        <div style="position: relative;">
          <span style="position: absolute; left: 16px; top: 50%; transform: translateY(-50%); font-size: 1.2rem; opacity: 0.5;">🔍</span>
          <input type="text" id="sozlukArama" placeholder="Finansal bir terim arayın... (Örn: Kaldıraç, Enflasyon)" style="width: 100%; padding: 16px 20px 16px 48px; background: rgba(0,0,0,0.4); border: 1px solid rgba(212,175,55,0.2); border-radius: 100px; color: var(--white); font-family: var(--font-body); font-size: 1.05rem; outline: none; transition: all 0.3s;" onfocus="this.style.borderColor='var(--gold-300)'; this.style.boxShadow='0 0 15px rgba(212,175,55,0.1)';" onblur="this.style.borderColor='rgba(212,175,55,0.2)'; this.style.boxShadow='none';">
        </div>
      </div>

      <!-- Harf Filtresi -->
      <div class="filter-bar reveal" style="gap: 6px; margin-bottom: 32px;">
        <button class="filter-btn active" data-filter="tumu">Tümü</button>
        <% 
          const harfler = [...new Set(sozluk.map(s => s.harf))].sort((a,b) => a.localeCompare(b, 'tr'));
          harfler.forEach(function(h) { 
        %>
          <button class="filter-btn" data-filter="<%= h %>" style="padding: 6px 14px; min-width: 40px; text-align: center;"><%= h %></button>
        <% }); %>
      </div>

      <!-- Sözlük Grid -->
      <div class="grid-3 stagger-children">
        <% sozluk.forEach(function(s) { %>
        <a href="/sozluk/<%= s.slug %>" style="text-decoration: none; display: block;" class="card" data-kategori="<%= s.harf %>">
          <div style="padding: 24px; display: flex; flex-direction: column; height: 100%;">
            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12px;">
              <h2 style="font-family: var(--font-display); color: var(--gold-200); font-size: 1.3rem; font-weight: 600; letter-spacing: 0.01em; line-height: 1.2;">
                <%= s.kavram %>
              </h2>
              <span style="font-family: var(--font-display); color: rgba(255,255,255,0.05); font-size: 3rem; line-height: 0.8; font-weight: 700; user-select: none;">
                <%= s.harf %>
              </span>
            </div>
            <p style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 16px; font-weight: 500; text-transform: uppercase; letter-spacing: 1px;">
              ENG: <%= s.ingilizce %>
            </p>
            <p style="font-size: 0.95rem; color: var(--text-secondary); line-height: 1.7; letter-spacing: 0.01em;">
              <%= s.aciklama.substring(0, 100) %>...
            </p>
            <div style="margin-top: auto; padding-top: 16px; font-size: 0.85rem; color: var(--gold-200); font-weight: 600; display: flex; align-items: center; gap: 4px;">
              Detayları İncele <span style="font-size: 1.1rem;">→</span>
            </div>
          </div>
        </a>
        <% }); %>
      </div>

    </div>
  </section>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const aramaInput = document.getElementById('sozlukArama');
      const cards = document.querySelectorAll('.card[data-kategori]');
      const filterBtns = document.querySelectorAll('.filter-btn');

      // Arama İşlevi
      aramaInput.addEventListener('input', (e) => {
        const aranan = e.target.value.toLowerCase('tr');
        
        // Arama yapılıyorsa harf butonlarındaki aktifliği kaldır
        if (aranan.length > 0) {
          filterBtns.forEach(btn => btn.classList.remove('active'));
        } else {
          // Arama kutusu boşaldıysa "Tümü" butonunu tekrar aktif yap
          document.querySelector('.filter-btn[data-filter="tumu"]').classList.add('active');
        }

        cards.forEach(card => {
          const baslik = card.querySelector('h2').textContent.toLowerCase('tr');
          const aciklama = card.querySelector('p:last-of-type').textContent.toLowerCase('tr');
          
          if (baslik.includes(aranan) || aciklama.includes(aranan)) {
            card.style.display = 'flex';
            card.style.animation = 'fadeInUp 0.4s ease forwards';
          } else {
            card.style.display = 'none';
          }
        });
      });
    });
  </script>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container reveal">
      <h2 class="cta-title">Kelimeler <span class="gold">Dünyanızı</span> Şekillendirir</h2>
      <p class="cta-desc">Finansal terimleri anladığınızda, fırsatları çok daha net görmeye başlayacaksınız.</p>
      <a href="/hesaplayici" class="btn btn-gold">Hesaplayıcıları Keşfet ✦</a>
    </div>
  </section>

<%- include('partials/footer') %>
