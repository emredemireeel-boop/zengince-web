<%- include('partials/header') %>

<!-- Forum CSS -->
<link rel="stylesheet" href="/forum.css">

<!-- FOUC Prevention: add class immediately before any paint -->
<script>
  if (localStorage.getItem('zengince_user')) {
    document.body.classList.add('logged-in');
  }
</script>

<!-- ═══════════════════════════════════════════════════════════════════════
     HERO SECTION
     ═══════════════════════════════════════════════════════════════════════ -->
<section class="hero" id="hero">
  <div class="hero-particles"></div>
  <div class="container">
    <div class="hero-content">
      <div class="hero-badge">Türkiye'nin Finans ve Yatırım Topluluğu</div>
      <h1 class="hero-title">
        Finansal Özgürlüğe Giden Yolda<br>
        <span class="hero-gold">Birlikte Kazanıyoruz</span>
      </h1>
      <p class="hero-subtitle">
        Binlerce yatırımcının deneyimi, uzman görüşleri ve portföy stratejileri tek çatı altında.
        Borsadan kriptoya, temettüden gayrimenkule kadar tüm fırsatlar Zengince Forum'da.
      </p>
      <div class="hero-actions">
        <a href="#forum-list" class="btn btn-gold">Forumu Keşfet</a>
        <a href="/kayit" class="btn btn-outline">Ücretsiz Katıl →</a>
      </div>
      <div class="hero-stats">
        <div class="hero-stat">
          <div class="hero-stat-number" data-count="<%= stats.totalThreads %>">0</div>
          <div class="hero-stat-label">Başlık</div>
        </div>
        <div class="hero-stat">
          <div class="hero-stat-number" data-count="<%= stats.totalEntries %>">0</div>
          <div class="hero-stat-label">Entry</div>
        </div>
        <div class="hero-stat">
          <div class="hero-stat-number" data-count="<%= stats.totalUsers %>">0</div>
          <div class="hero-stat-label">Üye</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════════════════════
     FORUM BÖLÜMÜ
     ═══════════════════════════════════════════════════════════════════════ -->
<div id="forum-subheader" style="background: var(--top-bar-bg); border-bottom: 1px solid var(--card-border); padding: 16px 24px;">
  <div class="container">
    <div class="subheader-row" style="display: flex; align-items: center; justify-content: space-between;">
      <div style="display: flex; align-items: center; gap: 12px;">
        <h1 style="font-size: 24px; font-weight: 700; color: var(--foreground);">Topluluk</h1>
      </div>

      <!-- Ticker -->
      <div class="fuel-ticker-wrapper glass" style="flex: 1; margin: 0 32px; overflow: hidden; border-radius: 12px; height: 44px; display: flex; align-items: center; position: relative;">
        <div style="display:flex; padding-left: 16px; align-items:center; gap: 32px; white-space: nowrap; overflow:hidden;" id="market-ticker-container">
          <span style="font-size: 11px; color: var(--gold-200); font-weight: 700; font-family: monospace; padding: 4px 8px; background: rgba(212,175,55,0.1); border-radius: 6px;">
            PİYASALAR
          </span>
          <span style="width: 1px; height: 18px; background: var(--card-border); display: inline-block; margin: 0 8px;"></span>
          <span style="color:var(--text-muted); font-size:12px;" id="ticker-loading">Canlı Veriler Yükleniyor...</span>
        </div>
      </div>

      <button class="new-topic-btn hover-lift" onclick="openNewThreadModal()" style="padding: 12px 24px; background: var(--gold-200); color: #111; font-weight: 700; border-radius: 12px; border: none; cursor: pointer; font-size: 14px; white-space: nowrap; display: flex; align-items: center; gap: 8px;">
        <span style="font-size: 18px; font-weight: bold;">+</span> Yeni Başlık
      </button>
    </div>
  </div>
</div>

<div class="container" style="padding: 24px;" id="forum-list">
  <div class="forum-main-grid">
    
    <!-- SOL SİDEBAR: Kategoriler -->
    <aside class="forum-left-sidebar">
      <div style="position: sticky; top: 100px; max-height: calc(100vh - 120px); overflow-y: auto; display: flex; flex-direction: column; gap: 16px;">

        <!-- Kategoriler -->
        <div style="background: var(--card-bg); border: 1px solid var(--card-border); border-radius: 16px; padding: 16px;">
          <h2 style="font-size: 14px; font-weight: 600; color: var(--text-muted); margin-bottom: 12px;">
            Kategoriler
          </h2>
          <ul style="list-style: none; padding: 0; margin: 0;" id="category-list">
            <li style="margin-bottom: 4px;">
              <a href="/forum" class="forum-cat-btn <%= (typeof pagination !== 'undefined' && !pagination.category) ? 'active' : '' %>" style="text-decoration: none;">
                <span style="flex: 1;">Tümü</span>
                <span class="forum-cat-badge"><%= stats.totalThreads %></span>
              </a>
            </li>
            <% forumKategorileri.forEach(cat => { 
                 let count = allBasliklar.filter(b => b.category === cat).length;
            %>
            <li style="margin-bottom: 4px;">
              <a href="/forum?category=<%= encodeURIComponent(cat) %>" class="forum-cat-btn <%= (typeof pagination !== 'undefined' && pagination.category === cat) ? 'active' : '' %>" style="text-decoration: none;">
                <span style="flex: 1;"><%= cat %></span>
                <span class="forum-cat-badge"><%= count %></span>
              </a>
            </li>
            <% }); %>
          </ul>
        </div>

        <!-- Altın Söz -->
        <% if (sidebar && sidebar.alinti) { %>
        <div style="background: linear-gradient(135deg, rgba(212, 175, 55, 0.08) 0%, var(--card-bg) 100%); border: 1px solid rgba(212, 175, 55, 0.15); border-radius: 16px; padding: 16px;">
          <div style="font-size: 11px; font-weight: 700; color: var(--gold-200); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 10px;">Altın Söz</div>
          <p style="font-size: 13px; color: var(--text-secondary); line-height: 1.6; font-style: italic; margin-bottom: 10px;">"<%= sidebar.alinti.soz %>"</p>
          <div style="font-size: 12px; color: var(--gold-200); font-weight: 600;">— <%= sidebar.alinti.kisi %></div>
          <a href="/alintilar" style="display: inline-block; margin-top: 10px; font-size: 11px; color: var(--text-muted); text-decoration: none; font-weight: 600;">Tüm Sözler →</a>
        </div>
        <% } %>

        <!-- Günün Alışkanlığı -->
        <% if (sidebar && sidebar.aliskanlik) { %>
        <div style="background: var(--card-bg); border: 1px solid var(--card-border); border-radius: 16px; padding: 16px;">
          <div style="font-size: 11px; font-weight: 700; color: var(--forum-success); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 10px;">Günün Alışkanlığı</div>
          <div style="font-size: 14px; font-weight: 700; color: var(--foreground); margin-bottom: 6px;"><%= sidebar.aliskanlik.baslik %></div>
          <p style="font-size: 12px; color: var(--text-muted); line-height: 1.5; margin-bottom: 10px;"><%= sidebar.aliskanlik.aciklama.substring(0, 120) %>...</p>
          <a href="/aliskanliklar" style="display: inline-block; font-size: 11px; color: var(--gold-200); text-decoration: none; font-weight: 600;">Alışkanlıklar →</a>
        </div>
        <% } %>

        <!-- Reklam Alanı (Sol) -->
        <div class="forum-ad-slot" style="background: var(--card-bg); border: 1px dashed rgba(255,255,255,0.08); border-radius: 16px; padding: 16px; text-align: center; min-height: 120px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6px; position: relative; overflow: hidden;">
          <div style="position: absolute; top: 6px; right: 8px; font-size: 9px; color: rgba(255,255,255,0.15); text-transform: uppercase; letter-spacing: 1px;">Reklam</div>
          <div style="width: 36px; height: 36px; border-radius: 8px; background: rgba(212,175,55,0.08); display: flex; align-items: center; justify-content: center; font-size: 12px; color: var(--text-muted); font-weight: 700;">AD</div>
          <div style="font-size: 12px; font-weight: 600; color: var(--text-muted);">Reklam Alanı</div>
          <div style="font-size: 10px; color: rgba(255,255,255,0.2);">220 × 120</div>
        </div>

      </div>
    </aside>

    <!-- ORTA ALAN: Başlıklar -->
    <main>
      <!-- Sort Bar -->
      <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; background: var(--card-bg); border: 1px solid var(--card-border); border-radius: 12px; padding: 8px 16px;">
        <div style="display: flex; gap: 8px;" id="sort-buttons">
          <a href="/forum?sort=newest<%= (typeof pagination !== 'undefined' && pagination.category) ? '&category=' + encodeURIComponent(pagination.category) : '' %>" class="sort-btn <%= (!pagination || !pagination.sort || pagination.sort === 'newest') ? 'active' : '' %>">
            En Yeni
          </a>
          <a href="/forum?sort=popular<%= (typeof pagination !== 'undefined' && pagination.category) ? '&category=' + encodeURIComponent(pagination.category) : '' %>" class="sort-btn <%= (typeof pagination !== 'undefined' && pagination.sort === 'popular') ? 'active' : '' %>">
            Popüler
          </a>
        </div>
        <div>
          <input type="text" id="forum-search" placeholder="Başlık ara..." style="padding: 8px 16px; border-radius: 8px; border: 1px solid var(--card-border); background: var(--background); color: var(--foreground); font-size: 13px; width: 220px;" onkeyup="searchForum(this.value)">
        </div>
      </div>

      <!-- Thread Listesi -->
      <div style="display: flex; flex-direction: column; gap: 16px;" id="thread-container">
        <% forumBasliklari.forEach(topic => { %>
        <a href="<%= topic.slugUrl %>" class="forum-topic-card topic-item" data-category="<%= topic.category %>" data-title="<%= topic.title.toLowerCase() %>">
          <div style="flex: 1; min-width: 0;">
            <!-- Category + badges -->
            <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 10px; flex-wrap: wrap;">
              <span style="padding: 4px 10px; background: var(--forum-secondary); color: var(--text-muted); font-size: 12px; border-radius: 6px; font-weight: 500;">
                <%= topic.category %>
              </span>
              <% if (topic.isHot) { %>
              <span style="padding: 4px 10px; background: rgba(212, 175, 55, 0.1); color: var(--gold-200); font-size: 12px; border-radius: 6px; font-weight: 600;">
                 Gündemde
              </span>
              <% } %>
            </div>

            <!-- Title -->
            <h2 style="font-size: 17px; font-weight: 600; color: var(--foreground); margin-bottom: 8px;">
              <%= topic.title %>
            </h2>

            <!-- Last entry preview -->
            <p style="color: var(--text-muted); font-size: 14px; margin-bottom: 12px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
              "<%= topic.lastEntry %>"
            </p>

            <!-- Footer -->
            <div style="display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--text-muted); flex-wrap: wrap;">
              <span style="white-space: nowrap; display: inline-flex; align-items: center; gap: 5px;">
                <%= topic.entryCount %> Entry
              </span>
              <span style="opacity: 0.5;">•</span>
              <span style="white-space: nowrap;"><%= topic.lastActivity %></span>
              <span style="opacity: 0.5;">•</span>
              <span style="display: flex; align-items: center; gap: 4px; white-space: nowrap;">
                <span style="width: 20px; height: 20px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 700; background: #333; color: #fff;">
                  <%= topic.lastAuthor.charAt(0).toUpperCase() %>
                </span>
                <span style="color: var(--gold-200);">@<%= topic.lastAuthor %></span>
              </span>
            </div>
          </div>

          <!-- Entry count -->
          <div style="text-align: right; flex-shrink: 0; padding-left: 16px; border-left: 1px solid var(--card-border); display: flex; flex-direction: column; justify-content: center;">
            <div class="topic-entry-count" style="font-size: 28px; font-weight: 700; color: var(--gold-200);"><%= topic.entryCount %></div>
            <div style="font-size: 12px; color: var(--text-muted);">Entry</div>
          </div>
        </a>
        <% }); %>
        
        <!-- Boş State (arama için) -->
        <div id="empty-state" style="display: none; text-align: center; padding: 40px; color: var(--text-muted); background: var(--card-bg); border-radius: 12px; border: 1px dashed var(--card-border);">
           <span style="font-size: 16px; display: block; margin-bottom: 16px; color: var(--text-muted);">—</span>
           <p>Sonuç bulunamadı.</p>
        </div>
      </div>

      <!-- Sayfalama (Pagination) -->
      <% if (typeof pagination !== 'undefined' && pagination.totalPages > 1) { %>
      <nav class="forum-pagination">
        <% if (pagination.hasPrev) { %>
          <a href="?page=<%= pagination.currentPage - 1 %><%= pagination.category ? '&category=' + encodeURIComponent(pagination.category) : '' %><%= pagination.sort ? '&sort=' + pagination.sort : '' %>">
            ← Önceki
          </a>
        <% } %>
        
        <% 
          let startPage = Math.max(1, pagination.currentPage - 2);
          let endPage = Math.min(pagination.totalPages, pagination.currentPage + 2);
          if (startPage > 1) { 
        %>
          <a href="?page=1<%= pagination.category ? '&category=' + encodeURIComponent(pagination.category) : '' %><%= pagination.sort ? '&sort=' + pagination.sort : '' %>">1</a>
          <% if (startPage > 2) { %>
            <span class="page-dots">…</span>
          <% } %>
        <% } %>
        
        <% for (let i = startPage; i <= endPage; i++) { %>
          <% if (i === pagination.currentPage) { %>
            <span class="page-current"><%= i %></span>
          <% } else { %>
            <a href="?page=<%= i %><%= pagination.category ? '&category=' + encodeURIComponent(pagination.category) : '' %><%= pagination.sort ? '&sort=' + pagination.sort : '' %>"><%= i %></a>
          <% } %>
        <% } %>
        
        <% if (endPage < pagination.totalPages) { %>
          <% if (endPage < pagination.totalPages - 1) { %>
            <span class="page-dots">…</span>
          <% } %>
          <a href="?page=<%= pagination.totalPages %><%= pagination.category ? '&category=' + encodeURIComponent(pagination.category) : '' %><%= pagination.sort ? '&sort=' + pagination.sort : '' %>"><%= pagination.totalPages %></a>
        <% } %>
        
        <% if (pagination.hasNext) { %>
          <a href="?page=<%= pagination.currentPage + 1 %><%= pagination.category ? '&category=' + encodeURIComponent(pagination.category) : '' %><%= pagination.sort ? '&sort=' + pagination.sort : '' %>">
            Sonraki →
          </a>
        <% } %>
      </nav>
      <% } %>

    </main>

    <!-- SAĞ SİDEBAR: Ekstra Araçlar -->
    <aside class="forum-right-sidebar">
      <div style="position: sticky; top: 100px; display: flex; flex-direction: column; gap: 16px;">
        
        <!-- Sözlük İpucu (Dinamik) -->
        <% if (sidebar && sidebar.sozluk) { %>
        <div style="background: linear-gradient(135deg, rgba(212, 175, 55, 0.1) 0%, rgba(20,20,20,0.9) 100%); border: 1px solid rgba(212, 175, 55, 0.2); border-radius: 16px; padding: 20px;">
          <div style="display: inline-block; padding: 4px 8px; background: var(--gold-200); color: #000; font-size: 11px; font-weight: 800; border-radius: 6px; margin-bottom: 12px;">SÖZLÜK</div>
          <h3 style="font-size: 16px; font-weight: 700; color: #fff; margin-bottom: 8px;"><%= sidebar.sozluk.terim %></h3>
          <p style="font-size: 13px; color: rgba(255,255,255,0.7); margin-bottom: 16px; line-height: 1.5;"><%= sidebar.sozluk.kisaTanim.substring(0, 140) %>...</p>
          <a href="/sozluk/<%= sidebar.sozluk.slug %>" style="display: inline-block; padding: 8px 16px; background: rgba(255,255,255,0.1); color: #fff; font-size: 12px; font-weight: 600; border-radius: 8px; text-decoration: none;">Sözlükte Oku →</a>
        </div>
        <% } %>

        <!-- Topluluk Liderleri -->
        <div style="background: var(--card-bg); border: 1px solid var(--card-border); border-radius: 16px; padding: 20px;">
          <h3 style="font-size: 15px; font-weight: 600; margin-bottom: 16px; color: var(--foreground);">Topluluk Liderleri</h3>
          <div style="display: flex; flex-direction: column; gap: 12px;">
            <div style="display: flex; align-items: center; justify-content: space-between;">
              <div style="display: flex; align-items: center; gap: 10px;">
                <div style="width: 32px; height: 32px; border-radius: 50%; background: #22c55e; color: #fff; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 14px;">V</div>
                <div>
                  <div style="font-size: 13px; font-weight: 600; color: var(--foreground);">value_investor</div>
                  <div style="font-size: 11px; color: var(--text-muted);">Efsane</div>
                </div>
              </div>
              <div style="font-size: 12px; font-weight: 700; color: var(--gold-200);">8.4k Entry</div>
            </div>
            <div style="display: flex; align-items: center; justify-content: space-between;">
              <div style="display: flex; align-items: center; gap: 10px;">
                <div style="width: 32px; height: 32px; border-radius: 50%; background: #a855f7; color: #fff; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 14px;">H</div>
                <div>
                  <div style="font-size: 13px; font-weight: 600; color: var(--foreground);">hodl_master</div>
                  <div style="font-size: 11px; color: var(--text-muted);">Tutkun</div>
                </div>
              </div>
              <div style="font-size: 12px; font-weight: 700; color: var(--gold-200);">3.2k Entry</div>
            </div>
          </div>
        </div>

        <!-- Usta Girişimci -->
        <% if (sidebar && sidebar.girisimci) { %>
        <div style="background: var(--card-bg); border: 1px solid var(--card-border); border-radius: 16px; padding: 20px;">
          <div style="font-size: 11px; font-weight: 700; color: #a855f7; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 12px;">Usta Girişimci</div>
          <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 10px;">
            <div style="width: 44px; height: 44px; border-radius: 50%; background: linear-gradient(135deg, #a855f7, #6d28d9); color: #fff; display: flex; align-items: center; justify-content: center; font-weight: 900; font-size: 18px; flex-shrink: 0;"><%= sidebar.girisimci.isim.charAt(0) %></div>
            <div>
              <div style="font-size: 14px; font-weight: 700; color: var(--foreground);"><%= sidebar.girisimci.isim %></div>
              <div style="font-size: 11px; color: var(--text-muted);"><%= sidebar.girisimci.unvan.substring(0, 40) %></div>
            </div>
          </div>
          <p style="font-size: 12px; color: var(--text-muted); line-height: 1.5; margin-bottom: 10px;"><%= sidebar.girisimci.ozet.substring(0, 100) %>...</p>
          <a href="/girisimciler/<%= sidebar.girisimci.slug %>" style="display: inline-block; font-size: 11px; color: var(--gold-200); text-decoration: none; font-weight: 600;">Hikayesini Oku →</a>
        </div>
        <% } %>

        <!-- Kitap Önerisi -->
        <% if (sidebar && sidebar.kitap) { %>
        <div style="background: var(--card-bg); border: 1px solid var(--card-border); border-radius: 16px; padding: 20px;">
          <div style="font-size: 11px; font-weight: 700; color: #f59e0b; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 12px;">Kitap Önerisi</div>
          <div style="font-size: 15px; font-weight: 700; color: var(--foreground); margin-bottom: 4px;"><%= sidebar.kitap.baslik %></div>
          <div style="font-size: 12px; color: var(--gold-200); margin-bottom: 8px;"><%= sidebar.kitap.yazar %> · <%= sidebar.kitap.puan %>/5</div>
          <p style="font-size: 12px; color: var(--text-muted); line-height: 1.5; margin-bottom: 10px;"><%= sidebar.kitap.ozet.substring(0, 100) %>...</p>
          <a href="/kitaplar/<%= sidebar.kitap.slug %>" style="display: inline-block; font-size: 11px; color: var(--gold-200); text-decoration: none; font-weight: 600;">İncele →</a>
        </div>
        <% } %>

        <!-- Reklam Alanı (Sağ) -->
        <div class="forum-ad-slot" style="background: var(--card-bg); border: 1px dashed rgba(255,255,255,0.08); border-radius: 16px; padding: 20px; text-align: center; min-height: 140px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px; position: relative; overflow: hidden;">
          <div style="position: absolute; top: 8px; right: 10px; font-size: 9px; color: rgba(255,255,255,0.15); text-transform: uppercase; letter-spacing: 1px;">Reklam</div>
          <div style="width: 40px; height: 40px; border-radius: 10px; background: rgba(212,175,55,0.08); display: flex; align-items: center; justify-content: center; font-size: 13px; color: var(--text-muted); font-weight: 700;">AD</div>
          <div style="font-size: 13px; font-weight: 600; color: var(--text-muted);">Reklam Alanı</div>
          <div style="font-size: 10px; color: rgba(255,255,255,0.2);">280 × 140</div>
        </div>

        <!-- Makale Önerisi -->
        <% if (sidebar && sidebar.makale) { %>
        <div style="background: var(--card-bg); border: 1px solid var(--card-border); border-radius: 16px; padding: 20px;">
          <div style="font-size: 11px; font-weight: 700; color: #3b82f6; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 12px;">Makale</div>
          <div style="font-size: 14px; font-weight: 700; color: var(--foreground); margin-bottom: 6px;"><%= sidebar.makale.baslik.substring(0, 60) %><%= sidebar.makale.baslik.length > 60 ? '...' : '' %></div>
          <div style="font-size: 11px; color: var(--text-muted); margin-bottom: 8px;"><%= sidebar.makale.yazar %> · <%= sidebar.makale.okumaSuresi %></div>
          <a href="/makaleler/<%= sidebar.makale.slug %>" style="display: inline-block; font-size: 11px; color: var(--gold-200); text-decoration: none; font-weight: 600;">Oku →</a>
        </div>
        <% } %>

      </div>
    </aside>

  </div>
</div>

<!-- Yeni Başlık Modalı -->
<div id="newThreadModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); z-index: 1000; align-items: center; justify-content: center; backdrop-filter: blur(5px);">
  <div style="background: var(--card-bg); width: 100%; max-width: 600px; border-radius: 16px; border: 1px solid rgba(212, 175, 55, 0.3); padding: 32px; position: relative; box-shadow: 0 20px 40px rgba(0,0,0,0.5);">
    <button onclick="document.getElementById('newThreadModal').style.display='none'" style="position: absolute; top: 16px; right: 16px; background: transparent; border: none; color: var(--text-muted); font-size: 24px; cursor: pointer;">&times;</button>
    <h2 style="font-size: 24px; color: #fff; margin-bottom: 24px;">Yeni Başlık Aç</h2>
    
    <div style="margin-bottom: 16px;">
      <label style="display: block; font-size: 13px; color: var(--text-muted); margin-bottom: 8px;">Başlık</label>
      <input type="text" id="nt-title" placeholder="Kısa ve öz bir başlık girin" style="width: 100%; padding: 12px 16px; border-radius: 8px; border: 1px solid var(--card-border); background: rgba(0,0,0,0.2); color: #fff;">
    </div>
    
    <div style="margin-bottom: 16px;">
      <label style="display: block; font-size: 13px; color: var(--text-muted); margin-bottom: 8px;">Kategori</label>
      <select id="nt-category" style="width: 100%; padding: 12px 16px; border-radius: 8px; border: 1px solid var(--card-border); background: rgba(0,0,0,0.2); color: #fff;">
        <% forumKategorileri.forEach(cat => { %>
          <option value="<%= cat %>"><%= cat %></option>
        <% }); %>
      </select>
    </div>
    
    <div style="margin-bottom: 24px;">
      <label style="display: block; font-size: 13px; color: var(--text-muted); margin-bottom: 8px;">İlk Mesajınız</label>
      <textarea id="nt-content" placeholder="Konunun detaylarını buraya yazın..." style="width: 100%; min-height: 120px; padding: 12px 16px; border-radius: 8px; border: 1px solid var(--card-border); background: rgba(0,0,0,0.2); color: #fff; resize: vertical;"></textarea>
    </div>

    <!-- Anket Ekleme (Opsiyonel) -->
    <div style="margin-bottom: 24px; padding: 16px; background: rgba(255,255,255,0.02); border: 1px dashed var(--card-border); border-radius: 8px;">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
        <label style="font-size: 13px; color: var(--text-muted); font-weight: 600;">Anket Ekle (İsteğe Bağlı)</label>
        <button onclick="addPollOption()" style="background: transparent; color: var(--gold-200); border: 1px solid var(--gold-200); border-radius: 6px; padding: 4px 8px; font-size: 12px; cursor: pointer;">+ Şık Ekle</button>
      </div>
      <div id="poll-options-container" style="display: flex; flex-direction: column; gap: 8px;">
        <!-- Şıklar buraya eklenecek -->
      </div>
    </div>
    
    <button id="nt-submit" class="btn btn-gold" style="width: 100%;" onclick="submitNewThread()">Başlığı Oluştur</button>
  </div>
</div>

<script>
  // ── Arama Filtreleme (Sayfadaki itemleri filtreler) ──
  function searchForum(query) {
    query = query.toLowerCase().trim();
    let visibleCount = 0;
    document.querySelectorAll('.topic-item').forEach(item => {
      const title = item.getAttribute('data-title');
      if (!query || title.includes(query)) {
        item.style.display = 'flex';
        visibleCount++;
      } else {
        item.style.display = 'none';
      }
    });

    const emptyState = document.getElementById('empty-state');
    if (visibleCount === 0 && query) {
      emptyState.style.display = 'block';
    } else {
      emptyState.style.display = 'none';
    }
  }

  // ── Modal Açma ──
  function openNewThreadModal() {
    const user = localStorage.getItem('zengince_user');
    if (!user) {
      window.location.href = '/giris';
      return;
    }
    document.getElementById('newThreadModal').style.display = 'flex';
  }

  // ── Anket Şık Ekleme ──
  function addPollOption() {
    const container = document.getElementById('poll-options-container');
    const div = document.createElement('div');
    div.style.display = 'flex';
    div.style.gap = '8px';
    div.innerHTML = `
      <input type="text" class="poll-option-input" placeholder="Şık yazın..." style="flex: 1; padding: 8px 12px; border-radius: 6px; border: 1px solid var(--card-border); background: rgba(0,0,0,0.4); color: #fff; font-size: 13px;">
      <button onclick="this.parentElement.remove()" style="background: rgba(239, 68, 68, 0.1); color: #ef4444; border: none; border-radius: 6px; padding: 0 12px; cursor: pointer;">Sil</button>
    `;
    container.appendChild(div);
  }

  // ── Yeni Başlık Gönderme ──
  async function submitNewThread() {
    const title = document.getElementById('nt-title').value.trim();
    const category = document.getElementById('nt-category').value;
    const content = document.getElementById('nt-content').value.trim();
    const username = localStorage.getItem('zengince_user');

    if (!title || !content) {
      if(window.showToast) window.showToast('Lütfen başlık ve içerik alanlarını doldurun.', 'error');
      else alert('Lütfen başlık ve içerik alanlarını doldurun.');
      return;
    }
    if (!username) {
      if(window.showToast) window.showToast('Lütfen giriş yapın.', 'error');
      else alert('Lütfen giriş yapın.');
      return;
    }

    // Anket şıklarını topla
    const pollInputs = document.querySelectorAll('.poll-option-input');
    const pollOptions = [];
    pollInputs.forEach(input => {
      const val = input.value.trim();
      if (val) pollOptions.push(val);
    });

    const btn = document.getElementById('nt-submit');
    btn.disabled = true;
    btn.textContent = 'Oluşturuluyor...';

    try {
      const res = await fetch('/api/new-thread', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ title, category, content, username, pollOptions })
      });
      const data = await res.json();
      
      if (data.success) {
        if(window.showToast) window.showToast('Başlık başarıyla oluşturuldu!', 'success');
        setTimeout(() => { window.location.href = data.redirectUrl; }, 1000);
      } else {
        if(window.showToast) window.showToast(data.error || 'Hata oluştu', 'error');
        else alert(data.error || 'Hata oluştu');
        btn.disabled = false;
        btn.textContent = 'Başlığı Oluştur';
      }
    } catch (e) {
      console.error(e);
      if(window.showToast) window.showToast('Sunucu hatası.', 'error');
      else alert('Sunucu hatası.');
      btn.disabled = false;
      btn.textContent = 'Başlığı Oluştur';
    }
  }
</script>


<script>
  async function loadLiveTicker() {
    try {
      const res = await fetch('/api/ticker');
      const json = await res.json();
      if (json.success && json.data) {
        const d = json.data;
        const container = document.getElementById('market-ticker-container');
        
        const formatMoney = (val, currency) => {
          return new Intl.NumberFormat('tr-TR', { maximumFractionDigits: 2 }).format(val) + ' ' + currency;
        };

        const formatChange = (change) => {
          const sign = change >= 0 ? '▲' : '▼';
          const color = change >= 0 ? 'var(--success)' : 'var(--danger)';
          return `<span style="color:${color};">${sign} %${Math.abs(change).toFixed(2)}</span>`;
        };

        let html = `
          <span style="font-size: 11px; color: var(--gold-200); font-weight: 700; font-family: monospace; padding: 4px 8px; background: rgba(212,175,55,0.1); border-radius: 6px;">
            PİYASALAR (CANLI)
          </span>
          <span style="width: 1px; height: 18px; background: var(--card-border); display: inline-block; margin: 0 8px;"></span>
        `;
        
        if (d.bist) {
          html += `
          <div style="display:flex; gap: 8px; font-size:12px;">
            <span style="color:var(--text-muted); font-weight:600;">BIST 100</span>
            <span style="font-weight:700; font-family:monospace;">${formatMoney(d.bist.price, '')}</span>
            ${formatChange(d.bist.change)}
          </div>`;
        }
        
        if (d.btc) {
          html += `
          <div style="display:flex; gap: 8px; font-size:12px;">
            <span style="color:var(--text-muted); font-weight:600;">Bitcoin</span>
            <span style="font-weight:700; font-family:monospace;">$${new Intl.NumberFormat('en-US').format(d.btc.price)}</span>
            ${formatChange(d.btc.change)}
          </div>`;
        }
        
        if (d.gold) {
          html += `
          <div style="display:flex; gap: 8px; font-size:12px;">
            <span style="color:var(--text-muted); font-weight:600;">Gram Altın</span>
            <span style="font-weight:700; font-family:monospace;">${formatMoney(d.gold.price, '₺')}</span>
            ${formatChange(d.gold.change)}
          </div>`;
        }
        
        if (!d.bist && !d.btc && !d.gold) {
          html += '<span style="color:var(--text-muted); font-size:12px;">Piyasa verileri alınamadı.</span>';
        }
        
        container.innerHTML = html;
      }
    } catch(e) {
      const el = document.getElementById('ticker-loading');
      if (el) el.textContent = 'Piyasa verileri alınamadı.';
    }
  }
  document.addEventListener('DOMContentLoaded', () => {
    loadLiveTicker();
    setInterval(loadLiveTicker, 30000);
  });
</script>

