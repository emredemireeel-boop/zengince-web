<%- include('partials/header') %>

  <!-- Page Header -->
  <section class="page-header">
    <div class="container">
      <span class="section-badge">📺 Dizi Analizi</span>
      <h1 class="section-title" style="margin-top:12px;">Zenginlik <span class="gold">Dizileri</span></h1>
      <p class="section-desc" style="margin:8px auto 0;">Güç, para ve strateji oyunlarını anlatan ustalık eseri diziler</p>
    </div>
  </section>

  <!-- Diziler Section -->
  <section class="section">
    <div class="container">
      <!-- Filter Bar -->
      <div class="filter-bar reveal">
        <button class="filter-btn active" data-filter="tumu">✦ Tümü</button>
        <% Object.keys(turler).forEach(function(key) { %>
        <button class="filter-btn" data-filter="<%= key %>"><%= turler[key].emoji %> <%= turler[key].baslik %></button>
        <% }); %>
      </div>

      <!-- Series Grid -->
      <div class="grid-3 stagger-children" id="diziler-grid">
        <% diziler.forEach(function(d) { %>
        <a href="/diziler/<%= d.slug %>" style="text-decoration: none; display: block;" class="film-card" data-kategori="<%= d.tur %>">
          <div class="film-card-poster" style="height: 300px; padding: 0; position: relative; border-radius: 12px 12px 0 0; overflow: hidden;">
            <img src="<%= d.afisGorseli %>" alt="<%= d.baslik %>" style="width: 100%; height: 100%; object-fit: cover; opacity: 0.9; transition: opacity 0.3s;" onmouseover="this.style.opacity='1';" onmouseout="this.style.opacity='0.9';">
          </div>
          <div class="film-card-body">
            <div class="film-card-meta">
              <span class="film-card-imdb">⭐ IMDb <%= d.imdb %></span>
              <span class="film-card-year-tag"><%= d.sezon %> Sezon</span>
              <span class="film-card-tur" style="background:<%= turler[d.tur].renk %>18;color:<%= turler[d.tur].renk %>;"><%= turler[d.tur].baslik %></span>
            </div>
            <h2 class="film-card-title"><%= d.baslik %></h2>
            <p class="film-card-turkce"><%= d.turkceBaslik %> · Yıl: <%= d.yil %></p>
            <p style="font-size:0.88rem;color:var(--text-secondary);line-height:1.6;margin-bottom:12px;"><%= d.ozet %></p>
            <div style="margin-top: auto; padding-top: 16px; font-size: 0.85rem; color: var(--gold-200); font-weight: 600; display: flex; align-items: center; gap: 4px;">
              İncelemeyi Oku <span style="font-size: 1.1rem;">→</span>
            </div>
          </div>
        </a>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container reveal">
      <h2 class="cta-title">İzleyerek <span class="gold">Öğrenin</span></h2>
      <p class="cta-desc">İş dünyasının zirvesindekilerin psikolojisini, kriz yönetimini ve güç savaşlarını kurgusal dünyalarda gözlemleyin.</p>
      <a href="/filmler" class="btn btn-gold">Filmleri Keşfet ✦</a>
    </div>
  </section>

<%- include('partials/footer') %>
