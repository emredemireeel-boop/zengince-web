<%- include('partials/header') %>

  <!-- Page Header -->
  <section class="page-header">
    <div class="container">
      <span class="section-badge">🎬 Sinematik Bilgelik</span>
      <h1 class="section-title" style="margin-top:12px;">Zenginlik <span class="gold">Filmleri</span></h1>
      <p class="section-desc" style="margin:8px auto 0;">Finansal dünyayı anlatan en etkileyici filmler ve belgeseller</p>
    </div>
  </section>

  <!-- Filmler Section -->
  <section class="section">
    <div class="container">
      <!-- Filter Bar -->
      <div class="filter-bar reveal">
        <button class="filter-btn active" data-filter="tumu">✦ Tümü</button>
        <% Object.keys(turler).forEach(function(key) { %>
        <button class="filter-btn" data-filter="<%= key %>"><%= turler[key].emoji %> <%= turler[key].baslik %></button>
        <% }); %>
      </div>

      <!-- Films Grid -->
      <div class="grid-3 stagger-children" id="filmler-grid">
        <% filmler.forEach(function(f) { %>
        <a href="/filmler/<%= f.slug %>" style="text-decoration: none; display: block;" class="film-card" data-kategori="<%= f.tur %>">
          <div class="film-card-poster" style="height: 300px; padding: 0; position: relative; border-radius: 12px 12px 0 0; overflow: hidden;">
            <img src="<%= f.afisGorseli %>" alt="<%= f.baslik %>" style="width: 100%; height: 100%; object-fit: cover; opacity: 0.9; transition: opacity 0.3s;" onmouseover="this.style.opacity='1';" onmouseout="this.style.opacity='0.9';">
          </div>
          <div class="film-card-body">
            <div class="film-card-meta">
              <span class="film-card-imdb">⭐ IMDb <%= f.imdb %></span>
              <span class="film-card-year-tag"><%= f.yil %></span>
              <span class="film-card-tur" style="background:<%= turler[f.tur].renk %>18;color:<%= turler[f.tur].renk %>;"><%= turler[f.tur].baslik %></span>
            </div>
            <h2 class="film-card-title"><%= f.baslik %></h2>
            <p class="film-card-turkce"><%= f.turkceBaslik %> · Yönetmen: <%= f.yonetmen %></p>
            <p style="font-size:0.88rem;color:var(--text-secondary);line-height:1.6;margin-bottom:12px;"><%= f.ozet %></p>
            <div style="margin-top: auto; padding-top: 16px; font-size: 0.85rem; color: var(--gold-200); font-weight: 600; display: flex; align-items: center; gap: 4px;">
              İncelemeyi Oku <span style="font-size: 1.1rem;">→</span>
            </div>
          </div>
        </a>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container reveal">
      <h2 class="cta-title">Hikayelerden <span class="gold">Ders Çıkarın</span></h2>
      <p class="cta-desc">En büyük dersler, başkalarının deneyimlerinden çıkar. Bu filmler, zenginliğin ışıklı ve karanlık yüzünü gösterir.</p>
      <a href="/kitaplar" class="btn btn-gold">Kitapları Keşfet ✦</a>
    </div>
  </section>

<%- include('partials/footer') %>
