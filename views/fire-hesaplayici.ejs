<%- include('partials/header') %>

  <!-- Page Header -->
  <section class="page-header" style="padding-bottom: 40px;">
    <div class="container">
      <span class="section-badge">🎯 FIRE (Financial Independence, Retire Early)</span>
      <h1 class="section-title" style="margin-top:12px;">Özgürlük <span class="gold">Hesaplayıcısı</span></h1>
      <p class="section-desc" style="margin:8px auto 0;">Hiçbir şey yapmadan, sadece yatırımlarınızın getirisiyle yaşayabilmek için ne kadarlık bir servete ihtiyacınız var?</p>
    </div>
  </section>

  <!-- FIRE Calculator Section -->
  <section class="section" style="padding-top: 0;">
    <div class="container">
      <div class="grid-2" style="gap: 40px; align-items: start;">
        
        <!-- Hesaplama Formu -->
        <div class="card" style="padding: 32px;">
          <h2 style="font-family: var(--font-display); color: var(--white); font-size: 1.4rem; margin-bottom: 8px;">Yaşam Maliyetiniz</h2>
          <p style="color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 24px;">Hayal ettiğiniz rahat yaşamın aylık faturasını çıkarın.</p>
          
          <div style="margin-bottom: 24px;">
            <label style="display: block; color: var(--text-primary); font-weight: 500; font-size: 0.95rem; margin-bottom: 8px;">Aylık İdeal Gideriniz (₺)</label>
            <p style="color: var(--text-muted); font-size: 0.8rem; margin-bottom: 8px;">Kira, faturalar, yeme-içme, tatil ve diğer tüm giderler dahil aylık ortalama harcamanız.</p>
            <input type="number" id="aylikGider" value="50000" style="width: 100%; padding: 14px 16px; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; color: var(--gold-200); font-weight: 600; font-family: var(--font-body); font-size: 1.2rem; outline: none; transition: border-color 0.3s;" onfocus="this.style.borderColor='var(--gold-300)'" onblur="this.style.borderColor='rgba(255,255,255,0.1)'">
          </div>

          <div style="margin-bottom: 32px;">
            <label style="display: block; color: var(--text-primary); font-weight: 500; font-size: 0.95rem; margin-bottom: 8px;">Güvenli Para Çekme Oranı (SWR)</label>
            <p style="color: var(--text-muted); font-size: 0.8rem; margin-bottom: 8px;">Genellikle %4 kabul edilir. %4 kuralı; enflasyona rağmen portföyünüzün ömrünüz boyunca hiç bitmemesi prensibine dayanır.</p>
            <select id="swrOrani" style="width: 100%; padding: 14px 16px; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; color: var(--white); font-family: var(--font-body); font-size: 1.1rem; outline: none;">
              <option value="3">Muhafazakar (%3) - Çok Daha Güvenli</option>
              <option value="4" selected>Standart (%4) - Trinity Çalışması</option>
              <option value="5">Agresif (%5) - Biraz Riskli</option>
            </select>
          </div>

          <button id="hesaplaBtn" class="btn btn-gold" style="width: 100%; justify-content: center; font-size: 1.1rem; padding: 16px;">Özgürlük Rakamımı Bul ✦</button>
        </div>

        <!-- Sonuç Alanı -->
        <div style="display: flex; flex-direction: column; gap: 24px;">
          
          <div class="card" style="padding: 40px 24px; text-align: center; background: linear-gradient(135deg, rgba(46, 204, 113, 0.08) 0%, var(--dark-700) 100%);">
            <div style="font-size: 3rem; margin-bottom: 16px;">🕊️</div>
            <p style="color: var(--text-secondary); font-size: 1rem; margin-bottom: 8px;">Çalışmayı Bırakabilmeniz İçin Gereken</p>
            <h2 style="font-family: var(--font-display); font-size: 1.8rem; color: var(--text-primary); font-weight: 500; margin-bottom: 4px;">Hedef Portföy Büyüklüğü</h2>
            <h1 id="hedefPortfoy" style="font-family: var(--font-display); font-size: 3.5rem; color: var(--emerald); font-weight: 700; margin-bottom: 16px;">₺0</h1>
            
            <p style="color: var(--text-muted); font-size: 0.9rem; line-height: 1.6; max-width: 400px; margin: 0 auto;">
              Eğer bu miktarda yatırımınız olursa, her yıl <strong id="yillikCekimYazi" style="color: var(--white);">₺0</strong> çekerek (enflasyon düzeltmeleriyle birlikte) teorik olarak paranız hiç bitmeden ömür boyu yaşayabilirsiniz.
            </p>
          </div>

          <div class="card" style="padding: 24px; border-left: 3px solid var(--gold-300);">
            <h3 style="font-family: var(--font-display); color: var(--white); font-size: 1.2rem; margin-bottom: 8px;">Matematik Nasıl İşliyor?</h3>
            <p style="color: var(--text-secondary); font-size: 0.9rem; line-height: 1.7;">
              Özgürlük Rakamı = Yıllık Gider / SWR.<br><br>
              Yani aylık giderinizi 12 ile çarpıp yıllık giderinizi buluyoruz. Daha sonra %4 kuralı gereği bu rakamı 25 ile (100/4) çarpıyoruz. Borsanın tarihsel ortalama getirisi %7-10 bandındadır, enflasyon %3 kabul edilirse, yatırımınızın %4'ünü yemek paranızı korur.
            </p>
          </div>

        </div>
      </div>
    </div>
  </section>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const aylikGiderInp = document.getElementById('aylikGider');
      const swrOraniInp = document.getElementById('swrOrani');
      const hesaplaBtn = document.getElementById('hesaplaBtn');
      
      const hedefPortfoyEl = document.getElementById('hedefPortfoy');
      const yillikCekimYaziEl = document.getElementById('yillikCekimYazi');

      const formatPara = (num) => {
        return new Intl.NumberFormat('tr-TR', { style: 'currency', currency: 'TRY', maximumFractionDigits: 0 }).format(num);
      };

      const hesapla = () => {
        const aylikGider = parseFloat(aylikGiderInp.value) || 0;
        const swrOrani = parseFloat(swrOraniInp.value) || 4;

        const yillikGider = aylikGider * 12;
        const carpan = 100 / swrOrani;
        const hedefPortfoy = yillikGider * carpan;

        // Sayı animasyonu efekti yapmadan direkt yazalım, temiz görünsün
        hedefPortfoyEl.textContent = formatPara(hedefPortfoy);
        yillikCekimYaziEl.textContent = formatPara(yillikGider);
      };

      hesaplaBtn.addEventListener('click', hesapla);
      hesapla(); // İlk yüklemede çalıştır
    });
  </script>

<%- include('partials/footer') %>
