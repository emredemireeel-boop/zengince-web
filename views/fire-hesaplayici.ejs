<%- include('partials/header') %>

<style>
  .calculator-section { padding: 120px 0 80px; }
  .calc-container { max-width: 1000px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 40px; }
  .calc-panel { background: rgba(20, 20, 20, 0.8); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 16px; padding: 40px; box-shadow: 0 20px 40px rgba(0,0,0,0.4); backdrop-filter: blur(10px); }
  .form-group { margin-bottom: 24px; }
  .form-label { display: block; font-weight: 600; margin-bottom: 8px; color: var(--text-secondary); }
  .form-control { width: 100%; padding: 16px; background: rgba(0, 0, 0, 0.5); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 8px; color: var(--white); font-size: 1.1rem; font-family: var(--font-body); }
  .form-control:focus { outline: none; border-color: #2ecc71; box-shadow: 0 0 0 3px rgba(46, 204, 113, 0.2); }
  
  .result-box { text-align: center; margin-bottom: 30px; }
  .result-title { font-size: 1rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px; }
  .result-value { font-size: 3rem; font-weight: 800; color: #2ecc71; font-family: var(--font-heading); line-height: 1; }
  
  .breakdown-list { list-style: none; padding: 0; margin: 0; }
  .breakdown-item { display: flex; justify-content: space-between; padding: 16px 0; border-bottom: 1px dashed rgba(255, 255, 255, 0.1); }
  .breakdown-item:last-child { border-bottom: none; }
  .bd-label { color: var(--text-secondary); font-size: 1.05rem; }
  .bd-value { color: var(--white); font-weight: 700; font-size: 1.1rem; }
  
  .btn-fire { background: #2ecc71; color: #fff; font-weight: 700; border: none; border-radius: 8px; cursor: pointer; transition: all 0.3s ease; }
  .btn-fire:hover { background: #27ae60; transform: translateY(-2px); box-shadow: 0 8px 20px rgba(46,204,113,0.3); }

  @media (max-width: 768px) {
    .calc-container { grid-template-columns: 1fr; }
  }
</style>

<section class="calculator-section">
  <div class="container">
    <div style="text-align: center; margin-bottom: 60px;">
      <span style="background: rgba(46, 204, 113, 0.1); color: #2ecc71; padding: 8px 16px; border-radius: 100px; font-weight: 700; text-transform: uppercase; font-size: 0.9rem; margin-bottom: 16px; display: inline-block;">🔥 Finansal Özgürlük</span>
      <h1 class="section-title">Erken Emeklilik (FIRE) <span style="color: #2ecc71;">Hesaplayıcı</span></h1>
      <p class="section-desc" style="max-width: 700px; margin: 0 auto;">Çalışmayı bırakıp sadece yatırımlarınızın getirisiyle yaşamak için ne kadar paraya ihtiyacınız var ve oraya kaç yılda ulaşırsınız?</p>
    </div>

    <div class="calc-container">
      
      <!-- Girdi Paneli -->
      <div class="calc-panel">
        <h2 style="font-size: 1.5rem; margin-bottom: 30px; color: var(--white);">Finansal Durumunuz</h2>
        
        <div class="form-group">
          <label class="form-label">Mevcut Birikiminiz (TL)</label>
          <input type="number" id="currentSavings" class="form-control" value="50000" min="0">
        </div>
        
        <div class="form-group">
          <label class="form-label">Aylık Tasarruf (Yatırım) (TL)</label>
          <input type="number" id="monthlySavings" class="form-control" value="5000" min="0">
        </div>
        
        <div class="form-group">
          <label class="form-label">Emeklilikte İstenen Aylık Gelir (TL)</label>
          <input type="number" id="monthlyExpenses" class="form-control" value="30000" min="0">
          <small style="color: var(--text-muted); margin-top: 6px; display: block;">Bugünün alım gücüyle hesaplayın. Enflasyon düşülecektir.</small>
        </div>

        <div class="form-group">
          <label class="form-label">Net Yıllık Getiri (% Enflasyon Sonrası)</label>
          <input type="number" id="netReturn" class="form-control" value="5" min="0" step="0.1">
          <small style="color: var(--text-muted); margin-top: 6px; display: block;">Tarihsel borsa getirisi (%10) - Enflasyon (%5) = %5 net.</small>
        </div>
        
        <div class="form-group">
          <label class="form-label">Güvenli Çekim Oranı (SWR %)</label>
          <input type="number" id="swr" class="form-control" value="4" min="1" max="10" step="0.1">
          <small style="color: var(--text-muted); margin-top: 6px; display: block;">Meşhur %4 Kuralı: Ana paranızı bitirmeden her yıl %4 çekebilirsiniz.</small>
        </div>

        <button onclick="calculateFIRE()" class="btn-fire" style="width: 100%; font-size: 1.2rem; padding: 18px; margin-top: 10px;">FIRE Hedefimi Hesapla 🔥</button>
      </div>

      <!-- Sonuç Paneli -->
      <div class="calc-panel">
        <div class="result-box">
          <div class="result-title">Finansal Özgürlük İçin Gereken Servet</div>
          <div class="result-value" id="fireNumber">0 ₺</div>
        </div>

        <div class="result-box" style="margin-top: 30px;">
          <div class="result-title" style="color: var(--white);">Buna Ulaşmanız İçin Gereken Süre</div>
          <div class="result-value" id="yearsToFire" style="font-size: 2.2rem; color: var(--white);">0 Yıl</div>
        </div>

        <ul class="breakdown-list" style="margin-top: 40px;">
          <li class="breakdown-item">
            <span class="bd-label">Emeklilikte Yıllık Gideriniz</span>
            <span class="bd-value" id="annualExpenses">0 ₺</span>
          </li>
          <li class="breakdown-item">
            <span class="bd-label">Mevcut Durum</span>
            <span class="bd-value" id="statusMessage" style="color: #2ecc71;">Hesaplanıyor...</span>
          </li>
        </ul>

        <div style="margin-top: 30px; padding: 20px; background: rgba(46, 204, 113, 0.1); border-left: 4px solid #2ecc71; border-radius: 8px; color: var(--text-primary); font-size: 0.95rem; line-height: 1.6;">
          <strong>💡 %4 Kuralı Nedir?</strong> Trinity çalışmasına göre yatırımlarınızın (genelde borsa) her yıl %4'ünü nakde çevirip harcarsanız, kalan para enflasyon karşısında erimeden size ömür boyu yetecektir.
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  function formatCurrency(num) {
    return new Intl.NumberFormat('tr-TR', { style: 'currency', currency: 'TRY', maximumFractionDigits: 0 }).format(num);
  }

  function calculateFIRE() {
    const currentSavings = parseFloat(document.getElementById('currentSavings').value) || 0;
    const monthlySavings = parseFloat(document.getElementById('monthlySavings').value) || 0;
    const monthlyExpenses = parseFloat(document.getElementById('monthlyExpenses').value) || 0;
    const netReturn = (parseFloat(document.getElementById('netReturn').value) || 0) / 100;
    const swr = (parseFloat(document.getElementById('swr').value) || 0) / 100;

    const annualExpenses = monthlyExpenses * 12;
    // FIRE Number: Annual expenses divided by SWR (usually 4%)
    const fireNumber = annualExpenses / swr;

    document.getElementById('annualExpenses').innerText = formatCurrency(annualExpenses);
    document.getElementById('fireNumber').innerText = formatCurrency(fireNumber);

    if (currentSavings >= fireNumber) {
      document.getElementById('yearsToFire').innerText = "Zaten Özgürsünüz! 🎉";
      document.getElementById('yearsToFire').style.color = "#2ecc71";
      document.getElementById('statusMessage').innerText = "Tebrikler, finansal özgürsünüz.";
      return;
    }

    if (monthlySavings <= 0 && netReturn <= 0) {
      document.getElementById('yearsToFire').innerText = "Asla 😢";
      document.getElementById('yearsToFire').style.color = "#e74c3c";
      document.getElementById('statusMessage').innerText = "Yatırım yapmadan ulaşamazsınız.";
      return;
    }

    // Calculate years to reach fireNumber
    let balance = currentSavings;
    let months = 0;
    const monthlyRate = netReturn / 12;

    // Safety net for infinite loop
    while (balance < fireNumber && months < 1200) { // Max 100 years
      balance += monthlySavings;
      balance *= (1 + monthlyRate);
      months++;
    }

    if (months >= 1200) {
      document.getElementById('yearsToFire').innerText = "100+ Yıl";
      document.getElementById('yearsToFire').style.color = "#e74c3c";
      document.getElementById('statusMessage').innerText = "Tasarrufu artırmalısınız.";
    } else {
      const years = Math.floor(months / 12);
      const remMonths = months % 12;
      document.getElementById('yearsToFire').innerText = `${years} Yıl, ${remMonths} Ay`;
      document.getElementById('yearsToFire').style.color = "#fff";
      document.getElementById('statusMessage').innerText = "Yolda ilerliyorsunuz.";
    }
  }

  // Init
  window.onload = calculateFIRE;
</script>

<%- include('partials/footer') %>
