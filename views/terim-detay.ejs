<%- include('partials/header') %>

<style>
  .terim-hero {
    padding: 80px 0 60px;
    background: linear-gradient(135deg, var(--dark-900) 0%, var(--dark-800) 100%);
    border-bottom: 1px solid rgba(212,175,55,0.1);
    position: relative;
    overflow: hidden;
  }
  .terim-hero::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(212,175,55,0.05) 0%, transparent 70%);
    z-index: 0;
  }
  .terim-container {
    max-width: 800px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .terim-badge {
    display: inline-block;
    padding: 6px 16px;
    background: rgba(255,255,255,0.05);
    border: 1px solid var(--gold-400);
    color: var(--gold-300);
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 20px;
  }
  .terim-title {
    font-size: 3rem;
    font-family: var(--font-display);
    color: var(--white);
    margin-bottom: 24px;
    line-height: 1.2;
  }
  .terim-summary {
    font-size: 1.2rem;
    line-height: 1.7;
    color: var(--text-100);
    border-left: 4px solid var(--gold-400);
    padding-left: 20px;
    margin-bottom: 40px;
  }
  .terim-content {
    padding: 60px 0;
  }
  .terim-content p {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--text-200);
    margin-bottom: 24px;
  }
  .terim-content h3 {
    margin-top: 40px;
    margin-bottom: 20px;
    font-size: 1.6rem;
    color: var(--white);
    font-family: var(--font-display);
  }
  .terim-content ul, .terim-content ol {
    margin-bottom: 24px;
    padding-left: 20px;
  }
  .terim-content li {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--text-200);
    margin-bottom: 12px;
  }
  .related-terms {
    background: var(--dark-800);
    padding: 30px;
    border-radius: var(--radius-lg);
    border: 1px solid rgba(255,255,255,0.05);
    margin-top: 40px;
  }
  .related-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 16px;
  }
  .tag {
    background: rgba(212,175,55,0.1);
    color: var(--gold-200);
    padding: 8px 16px;
    border-radius: 6px;
    font-size: 0.9rem;
    text-decoration: none;
    transition: all 0.3s;
  }
  .tag:hover {
    background: var(--gold-400);
    color: var(--dark-900);
  }
</style>

<div class="terim-hero">
  <div class="container terim-container">
    <div class="terim-badge">📖 <%= terim.kategori %></div>
    <h1 class="terim-title"><%= terim.terim %></h1>
    <div class="terim-summary">
      <%= terim.kisaTanim %>
    </div>
  </div>
</div>

<div class="container terim-container">
  <div class="terim-content">
    <%- terim.detay %>
    
    <% if (terim.ilgiliTerimler && terim.ilgiliTerimler.length > 0) { %>
      <div class="related-terms">
        <h3 style="margin-top: 0; color: var(--gold-300); font-size: 1.3rem;">Bununla da İlgilenebilirsiniz</h3>
        <div class="related-tags">
          <% terim.ilgiliTerimler.forEach(function(ilgili) { %>
            <span class="tag" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: var(--text-secondary); cursor: default;"><%= ilgili %></span>
          <% }); %>
        </div>
      </div>
    <% } %>
    
    <!-- Geri Dön Butonu -->
    <div style="margin-top: 60px; text-align: center;">
      <a href="/sozluk" class="btn btn-outline" style="padding: 12px 32px;">← Sözlüğe Dön</a>
    </div>
  </div>
</div>

<!-- Diğer Terimler -->
<section class="section" style="background: var(--dark-900); border-top: 1px solid var(--glass-border);">
  <div class="container">
    <h2 class="section-title" style="margin-bottom: 40px; font-size: 2rem;">Sözlükte Keşfetmeye Devam Et</h2>
    <div class="grid-3 stagger-children">
      <% rastgeleTerimler.slice(0,3).forEach(function(t) { %>
        <a href="/sozluk/<%= t.slug %>" class="card" style="text-decoration: none; display: flex; flex-direction: column; height: 100%;">
          <h3 style="font-size: 1.2rem; color: var(--gold-300); margin-bottom: 12px;"><%= t.terim %></h3>
          <p style="color: var(--text-secondary); font-size: 0.9rem; line-height: 1.6; margin-bottom: 16px; flex-grow: 1;">
            <%= t.kisaTanim %>
          </p>
          <div style="color: var(--gold-200); font-size: 0.9rem; font-weight: 600;">İncele →</div>
        </a>
      <% }); %>
    </div>
  </div>
</section>


<section class="section" style="padding-top: 0;">
  <div class="container">
    <%- include('partials/comments', { pageId: 'terim_' + terim.slug }) %>
  </div>
</section>

<%- include('partials/footer') %>
