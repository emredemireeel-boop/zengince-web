<%- include('partials/header') %>

  <!-- Page Header -->
  <section class="page-header" style="background: linear-gradient(135deg, rgba(212, 175, 55, 0.1) 0%, rgba(10,10,10,1) 100%);">
    <div class="container" style="text-align: center;">
      <span class="section-badge" style="background: rgba(212, 175, 55, 0.15); border-color: rgba(212, 175, 55, 0.3); color: var(--gold-300);">🏆 Vaka Analizleri</span>
      <h1 class="section-title">Tarihin En Büyük <span class="gold">Deha Hamleleri</span></h1>
      <p class="section-desc" style="max-width: 800px; margin: 0 auto;">
        Sıfırdan milyar dolarlık imparatorluklara uzanan yolda, kuralları yıkan, oyunun kurallarını yeniden yazan ve "iş dünyasının matematiğini" hackleyen tarihin en zekice finansal hamleleri.
      </p>
    </div>
  </section>

  <!-- Content Grid -->
  <section class="section" style="padding-top: 20px;">
    <div class="container">
      <div class="grid-3 stagger-children">
        <% hamleler.forEach(function(h) { %>
        <div class="card" style="display: flex; flex-direction: column; overflow: hidden; padding: 0;">
          <div style="position: relative; height: 200px; overflow: hidden;">
            <img src="<%= h.kapakGorseli %>" alt="<%= h.baslik %>" style="width: 100%; height: 100%; object-fit: cover; border-bottom: 1px solid rgba(255,255,255,0.05); filter: brightness(0.8) contrast(1.1);">
            <div style="position: absolute; top: 12px; right: 12px; background: rgba(0,0,0,0.8); border: 1px solid var(--gold-400); color: var(--gold-300); padding: 4px 10px; border-radius: 6px; font-size: 0.8rem; font-weight: 600;">
              <%= h.yil %>
            </div>
          </div>
          
          <div style="padding: 24px; display: flex; flex-direction: column; flex: 1;">
            <% if (kategoriler[h.kategori]) { %>
            <div style="display: flex; align-items: center; gap: 6px; margin-bottom: 12px;">
              <span><%= kategoriler[h.kategori].emoji %></span>
              <span style="color: <%= kategoriler[h.kategori].renk %>; font-size: 0.85rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px;">
                <%= h.kategori %>
              </span>
            </div>
            <% } %>
            
            <h3 class="card-title" style="font-size: 1.25rem; margin-bottom: 8px;"><%= h.baslik %></h3>
            <p style="color: var(--gold-200); font-size: 0.9rem; font-weight: 600; margin-bottom: 12px; font-style: italic;">
              <%= h.kisi_sirket %>
            </p>
            
            <p class="card-text" style="flex: 1; margin-bottom: 24px;"><%= h.ozet %></p>
            
            <a href="/deha-hamleleri/<%= h.slug %>" class="btn btn-outline" style="align-self: flex-start; border-color: var(--gold-400); color: var(--gold-300);">
              Vaka Analizini Oku →
            </a>
          </div>
        </div>
        <% }); %>
      </div>
    </div>
  </section>

<%- include('partials/footer') %>
