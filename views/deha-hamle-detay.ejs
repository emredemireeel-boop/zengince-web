<%- include('partials/header') %>

  <!-- Cinematic Article Header -->
  <header style="position: relative; height: 60vh; min-height: 500px; display: flex; align-items: flex-end; padding-bottom: 60px; border-bottom: 1px solid rgba(212, 175, 55, 0.3);">
    <div style="position: absolute; inset: 0; background: url('<%= h.kapakGorseli %>') center/cover; z-index: 0;"></div>
    <div style="position: absolute; inset: 0; background: linear-gradient(0deg, rgba(10,10,10,1) 0%, rgba(10,10,10,0.8) 40%, rgba(10,10,10,0.3) 100%); z-index: 1;"></div>
    
    <div class="container" style="position: relative; z-index: 2; width: 100%;">
      <div style="max-width: 900px;">
        <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 24px; flex-wrap: wrap;">
          <% if (kategori_bilgisi) { %>
          <span style="background: rgba(0,0,0,0.7); padding: 8px 16px; border-radius: 8px; font-size: 0.9rem; font-weight: 700; color: <%= kategori_bilgisi.renk %>; border: 1px solid rgba(255,255,255,0.1); backdrop-filter: blur(8px); text-transform: uppercase; letter-spacing: 1px;">
            <%= kategori_bilgisi.emoji %> <%= h.kategori %>
          </span>
          <% } %>
          <span style="background: rgba(212, 175, 55, 0.15); padding: 8px 16px; border-radius: 8px; font-size: 0.9rem; font-weight: 700; color: var(--gold-400); border: 1px solid rgba(212, 175, 55, 0.3); backdrop-filter: blur(8px); text-transform: uppercase; letter-spacing: 1px;">
            🏆 Deha Hamlesi
          </span>
        </div>

        <h1 style="font-family: var(--font-display); font-size: clamp(2.5rem, 6vw, 4.5rem); line-height: 1.1; color: var(--white); margin-bottom: 24px; text-shadow: 0 4px 20px rgba(0,0,0,0.9); letter-spacing: -1px;">
          <%= h.baslik %>
        </h1>
        
        <p style="font-size: 1.35rem; color: #E0E0E0; line-height: 1.6; max-width: 800px; text-shadow: 0 2px 10px rgba(0,0,0,0.9); font-weight: 400;">
          <%= h.ozet %>
        </p>
      </div>
    </div>
  </header>

  <!-- Article Layout with Sidebar -->
  <section style="padding: 80px 0; background: var(--bg-dark);">
    <div class="container">
      <div style="display: grid; grid-template-columns: 1fr 350px; gap: 60px; align-items: start;">
        
        <!-- Main Content (Left) -->
        <article class="article-body" style="font-size: 1.15rem; line-height: 1.8; color: #D1D5DB;">
          <%- h.icerik %>
          
          <!-- Back & Share Section -->
          <div style="margin-top: 80px; padding-top: 40px; border-top: 1px solid rgba(255,255,255,0.1); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 20px;">
            <a href="/deha-hamleleri" class="btn btn-outline" style="border-color: var(--gold-400); color: var(--gold-300); padding: 12px 24px;">
              ← Tüm Vakalara Dön
            </a>
            
            <div style="display: flex; gap: 16px; align-items: center;">
              <span style="color: var(--text-secondary); font-size: 0.95rem; font-weight: 600; text-transform: uppercase; letter-spacing: 1px;">Paylaş</span>
              <button onclick="navigator.clipboard.writeText(window.location.href); alert('Bağlantı kopyalandı!');" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: var(--white); width: 45px; height: 45px; border-radius: 50%; cursor: pointer; transition: all 0.3s ease; display: flex; align-items: center; justify-content: center; font-size: 1.2rem;" onmouseover="this.style.background='rgba(212, 175, 55, 0.2)'; this.style.borderColor='var(--gold-400)';" onmouseout="this.style.background='rgba(255,255,255,0.05)'; this.style.borderColor='rgba(255,255,255,0.1)';">
                🔗
              </button>
            </div>
          </div>
        </article>

        <!-- Sidebar Factbox (Right) -->
        <aside style="position: sticky; top: 100px;">
          <div style="background: rgba(20, 20, 20, 0.8); border: 1px solid rgba(255,255,255,0.05); border-radius: 16px; padding: 30px; box-shadow: 0 20px 40px rgba(0,0,0,0.4); backdrop-filter: blur(10px);">
            <h3 style="font-family: var(--font-display); color: var(--gold-300); font-size: 1.5rem; margin-bottom: 24px; border-bottom: 1px solid rgba(212, 175, 55, 0.2); padding-bottom: 16px;">
              Vaka Künyesi
            </h3>
            
            <div style="display: flex; flex-direction: column; gap: 20px;">
              <div>
                <span style="display: block; font-size: 0.85rem; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px;">Aktör / Şirket</span>
                <strong style="color: var(--white); font-size: 1.2rem;"><%= h.kisi_sirket %></strong>
              </div>
              
              <div>
                <span style="display: block; font-size: 0.85rem; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px;">Gerçekleşme Yılı</span>
                <strong style="color: var(--white); font-size: 1.2rem;"><%= h.yil %></strong>
              </div>

              <div>
                <span style="display: block; font-size: 0.85rem; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px;">Sektör / Endüstri</span>
                <strong style="color: <%= kategori_bilgisi ? kategori_bilgisi.renk : 'var(--white)' %>; font-size: 1.1rem;"><%= h.kategori %></strong>
              </div>
            </div>

            <div style="margin-top: 30px; padding-top: 24px; border-top: 1px dashed rgba(255,255,255,0.1);">
              <span style="display: block; font-size: 0.85rem; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px;">Zengince Zeka Skoru</span>
              <div style="display: flex; align-items: baseline; gap: 4px;">
                <span style="font-family: var(--font-display); font-size: 3rem; color: var(--gold-400); font-weight: 800; line-height: 1;">9.9</span>
                <span style="color: var(--text-secondary); font-size: 1.2rem;">/ 10</span>
              </div>
              <p style="color: var(--text-secondary); font-size: 0.85rem; margin-top: 8px; font-style: italic;">"Bu hamle, işletme fakültelerinde ders olarak okutulacak düzeyde kusursuzdur."</p>
            </div>
          </div>
        </aside>

      </div>
    </div>
  </section>
  
  <style>
    /* Responsive adjustment for sidebar grid */
    @media (max-width: 992px) {
      div[style*="grid-template-columns: 1fr 350px;"] {
        grid-template-columns: 1fr !important;
      }
      aside {
        position: static !important;
        margin-top: 40px;
      }
    }
  </style>

<!-- JSON-LD Schema Markup -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "<%- h.baslik %>",
  "description": "<%- h.ozet %>",
  "image": "<%- h.kapakGorseli %>",
  "author": {
    "@type": "Organization",
    "name": "Zengince"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Zengince",
    "logo": {
      "@type": "ImageObject",
      "url": "https://zengince.com/favicon.svg"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://zengince.com<%- path %>/<%- h.slug %>"
  }
}
</script>


<section class="section" style="padding-top: 0;">
  <div class="container">
    <%- include('partials/comments', { pageId: 'deha_' + h.slug }) %>
  </div>
</section>

<%- include('partials/footer') %>
