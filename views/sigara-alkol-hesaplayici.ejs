<%- include('partials/header') %>

  <!-- Page Header -->
  <section class="page-header" style="padding-bottom: 40px;">
    <div class="container">
      <span class="section-badge">☠️ Zehirli Alışkanlıklar</span>
      <h1 class="section-title" style="margin-top:12px;">Sigara ve Alkol <span class="ruby">Maliyeti</span></h1>
      <p class="section-desc" style="margin:8px auto 0;">Hem sağlığınızı hem de gelecekteki servetinizi nasıl yok ediyorsunuz? Kendinizi zehirlemek için sigara ve alkol şirketlerine kaç milyon TL ödediğinizi hesaplayın.</p>
    </div>
  </section>

  <!-- Hesaplayıcı Section -->
  <section class="section" style="padding-top: 0;">
    <div class="container">
      <div class="grid-2" style="gap: 40px;">
        
        <!-- Girdiler -->
        <div class="card" style="padding: 32px; display: flex; flex-direction: column; gap: 24px;">
          <h3 style="color: var(--white); font-family: var(--font-display); font-size: 1.4rem; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 16px;">Tüketim Profili</h3>
          
          <div class="input-group">
            <label style="display: block; margin-bottom: 8px; color: var(--text-secondary); font-size: 0.95rem;">Günlük Sigara Tüketimi (Paket)</label>
            <input type="number" id="gunlukSigara" value="1" step="0.5" style="width: 100%; padding: 12px 16px; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; color: var(--white); font-size: 1.1rem; outline: none; transition: border-color 0.3s ease;">
          </div>
          
          <div class="input-group">
            <label style="display: block; margin-bottom: 8px; color: var(--text-secondary); font-size: 0.95rem;">Güncel Paket Fiyatı (₺)</label>
            <input type="number" id="sigaraFiyat" value="65" style="width: 100%; padding: 12px 16px; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; color: var(--white); font-size: 1.1rem; outline: none; transition: border-color 0.3s ease;">
          </div>

          <div class="input-group" style="margin-top: 12px;">
            <label style="display: block; margin-bottom: 8px; color: var(--text-secondary); font-size: 0.95rem;">Haftalık Alkol Tüketimi (Kadeh/Şişe/Kutu)</label>
            <input type="number" id="haftalikAlkol" value="4" style="width: 100%; padding: 12px 16px; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; color: var(--white); font-size: 1.1rem; outline: none; transition: border-color 0.3s ease;">
          </div>

          <div class="input-group">
            <label style="display: block; margin-bottom: 8px; color: var(--text-secondary); font-size: 0.95rem;">Ortalama Alkol Birim Fiyatı (₺)</label>
            <input type="number" id="alkolFiyat" value="150" style="width: 100%; padding: 12px 16px; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; color: var(--white); font-size: 1.1rem; outline: none; transition: border-color 0.3s ease;">
          </div>

          <div class="input-group" style="margin-top: 12px;">
            <label style="display: block; margin-bottom: 8px; color: var(--text-secondary); font-size: 0.95rem;">Yıllık Beklenen Yatırım Getirisi (%)</label>
            <input type="number" id="yillikGetiri" value="40" style="width: 100%; padding: 12px 16px; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; color: var(--white); font-size: 1.1rem; outline: none; transition: border-color 0.3s ease;">
          </div>

          <div class="input-group" style="margin-top: 16px;">
            <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
              <label style="color: var(--text-secondary); font-size: 0.95rem;">Zaman Ufku (Yıl)</label>
              <span id="yilGosterge" style="color: var(--ruby); font-weight: 600;">10 Yıl</span>
            </div>
            <input type="range" id="yilSlider" min="1" max="40" value="10" style="width: 100%; accent-color: var(--ruby);">
          </div>

        </div>

        <!-- Sonuçlar -->
        <div style="display: flex; flex-direction: column; gap: 24px;">
          <div class="card" style="padding: 32px; text-align: center; position: relative; overflow: hidden; height: 100%; display: flex; flex-direction: column; justify-content: center;">
            <div style="position: absolute; top:0; left:0; right:0; height: 4px; background: linear-gradient(90deg, #1a1a1a 0%, var(--ruby) 100%);"></div>
            
            <p style="color: var(--text-secondary); font-size: 1.1rem; margin-bottom: 8px;">Zehirlenmek İçin Cepten Çıkan Toplam Para</p>
            <h3 id="toplamOdeme" style="font-family: var(--font-display); font-size: 2rem; color: var(--text-muted); margin-bottom: 24px;">₺0</h3>

            <p style="color: var(--emerald); font-size: 1.2rem; margin-bottom: 8px; font-weight: 500;">Bunu Yatırıma Dönüştürseydiniz Servetiniz</p>
            <h2 id="gelecekServet" style="font-family: var(--font-display); font-size: 4rem; color: var(--emerald); font-weight: 600; margin-bottom: 16px; letter-spacing: -1px;">₺0</h2>
            <p id="durumMesaji" style="color: var(--ruby); font-size: 1.1rem; font-weight: 500; padding: 0 20px;">Kendi ölümünüzü finanse ediyorsunuz.</p>
            
            <div style="margin-top: 40px; padding-top: 24px; border-top: 1px solid rgba(255,255,255,0.05); text-align: left;">
              <h4 style="color: var(--white); margin-bottom: 16px; font-size: 1.1rem;">📉 Acı Fatura Tablosu</h4>
              
              <div style="display: flex; justify-content: space-between; margin-bottom: 12px;">
                <span style="color: var(--text-secondary);">Aylık Zehir Maliyeti:</span>
                <span id="aylikMaliyet" style="color: var(--ruby); font-weight: bold;">₺0</span>
              </div>
              <div style="display: flex; justify-content: space-between; margin-bottom: 12px;">
                <span style="color: var(--text-secondary);">Yıllık Zehir Maliyeti:</span>
                <span id="yillikMaliyet" style="color: var(--ruby); font-weight: bold;">₺0</span>
              </div>
              <div style="display: flex; justify-content: space-between; margin-bottom: 12px; padding-top: 12px; border-top: 1px dashed rgba(255,255,255,0.1);">
                <span style="color: var(--text-secondary);">Vazgeçilen Fırsat Maliyeti:</span>
                <span id="kacirilanKar" style="color: var(--gold-400); font-weight: bold;">₺0</span>
              </div>
            </div>

          </div>
        </div>

      </div>
    </div>
  </section>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const inputs = [
        document.getElementById('gunlukSigara'),
        document.getElementById('sigaraFiyat'),
        document.getElementById('haftalikAlkol'),
        document.getElementById('alkolFiyat'),
        document.getElementById('yillikGetiri')
      ];
      
      const yilSlider = document.getElementById('yilSlider');
      const yilGosterge = document.getElementById('yilGosterge');

      const toplamOdemeEl = document.getElementById('toplamOdeme');
      const gelecekServetEl = document.getElementById('gelecekServet');
      const durumMesajiEl = document.getElementById('durumMesaji');
      const aylikMaliyetEl = document.getElementById('aylikMaliyet');
      const yillikMaliyetEl = document.getElementById('yillikMaliyet');
      const kacirilanKarEl = document.getElementById('kacirilanKar');

      const formatPara = (num) => {
        return new Intl.NumberFormat('tr-TR', { style: 'currency', currency: 'TRY', maximumFractionDigits: 0 }).format(num);
      };

      const hesapla = () => {
        const p_sigara = parseFloat(inputs[0].value) || 0;
        const f_sigara = parseFloat(inputs[1].value) || 0;
        const h_alkol = parseFloat(inputs[2].value) || 0;
        const f_alkol = parseFloat(inputs[3].value) || 0;
        const yillikGetiriOrani = parseFloat(inputs[4].value) || 0;
        const yillar = parseInt(yilSlider.value) || 0;

        yilGosterge.textContent = yillar + " Yıl";

        // Aylık Maliyetler
        const aylikSigara = (p_sigara * f_sigara) * 30;
        // 1 ay ortalama 4.33 hafta
        const aylikAlkol = (h_alkol * f_alkol) * 4.333;
        
        const aylikToplamZehir = aylikSigara + aylikAlkol;
        const yillikToplamZehir = aylikToplamZehir * 12;
        const toplamAnaPara = yillikToplamZehir * yillar;

        // Bileşik Getiri Hesabı (Aylık yatırım varsayımı)
        const aylikGetiriOrani = (yillikGetiriOrani / 100) / 12;
        const toplamAy = yillar * 12;
        let toplamServet = 0;

        for (let i = 0; i < toplamAy; i++) {
          toplamServet += aylikToplamZehir;
          toplamServet = toplamServet * (1 + aylikGetiriOrani);
        }

        const kacirilanKar = toplamServet - toplamAnaPara;

        // DOM Update
        toplamOdemeEl.textContent = formatPara(toplamAnaPara);
        gelecekServetEl.textContent = formatPara(toplamServet);
        aylikMaliyetEl.textContent = formatPara(aylikToplamZehir);
        yillikMaliyetEl.textContent = formatPara(yillikToplamZehir);
        kacirilanKarEl.textContent = formatPara(kacirilanKar);

        // Psikolojik Mesaj
        if (toplamServet > 10000000) {
          durumMesajiEl.textContent = "Felaket! Kendi ölümünüzü finanse ederken aynı zamanda milyonluk bir imparatorluğu da yakıp yıktınız.";
          durumMesajiEl.style.color = "var(--ruby)";
        } else if (toplamServet > 3000000) {
          durumMesajiEl.textContent = "Ciğerlerinizi çürütmek için ailenizin gelecekteki servetinden çalıyorsunuz.";
          durumMesajiEl.style.color = "var(--ruby)";
        } else if (toplamServet > 0) {
          durumMesajiEl.textContent = "Hem sağlığınızı kaybediyorsunuz, hem de finansal özgürlüğünüzü eritiyorsunuz.";
          durumMesajiEl.style.color = "var(--gold-400)";
        } else {
          durumMesajiEl.textContent = "Tebrikler, bu harcamalarınız yok. Sağlığınızı ve servetinizi koruyorsunuz!";
          durumMesajiEl.style.color = "var(--emerald)";
        }
      };

      // Dinleyiciler
      inputs.forEach(inp => {
        inp.addEventListener('input', hesapla);
        inp.addEventListener('focus', function() { this.style.borderColor = 'var(--ruby)'; });
        inp.addEventListener('blur', function() { this.style.borderColor = 'rgba(255,255,255,0.1)'; });
      });

      yilSlider.addEventListener('input', hesapla);

      // İlk yükleme
      hesapla();
    });
  </script>

<%- include('partials/footer') %>
